ections": {"译文": "远看山上有颜色，走近听水却听不到水声。春天过去了花还开着，人走来鸟也不惊飞。", "注释": "- **色**：颜色。\n- **惊**：惊飞，害怕。", "赏析": "这是一首以\"画\"为题的谜语诗。诗句句句写画中景，却又与现实相反：山有色而水无声，春去花在，人来鸟不惊。全诗不着一\"画\"字，却处处点题，构思精巧，是儿童读诗启蒙的佳作。", "作者": "王维（701年－761年），字摩诘，唐代著名诗人、画家。苏轼赞其\"诗中有画，画中有诗\"。其山水田园诗成就最高，与孟浩然并称\"王孟\"。"}}, {"title": "登科后", "poet": "孟郊", "dynasty": "唐", "type": "七言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "登鹤雀楼", "poet": "王之渤", "dynasty": "唐", "type": "五言绝句", "theme": "哲理", "tags": ["哲理", "登高", "黄河"], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": ["白日依山尽，", "黄河入海流。", "欲穷千里目，", "更上一层楼。"], "ruby": [[["白", "bái"], ["日", "rì"], ["依", "yī"], ["山", "shān"], ["尽", "jǐn"], ["，", ""]], [["黄", "huáng"], ["河", "hé"], ["入", "rù"], ["海", "hǎi"], ["流", "liú"], ["。", ""]], [["欲", "yù"], ["穷", "qióng"], ["千", "qiān"], ["里", "lǐ"], ["目", "mù"], ["，", ""]], [["更", "gèng"], ["上", "shàng"], ["一", ""], ["层", "céng"], ["楼", "lóu"], ["。", ""]]], "sections": {"译文": "夕阳傍着远山沉落，黄河向大海奔流。想要看到更远的地方，就要再登上一层高楼。", "注释": "笔老悠然", "赏析": "前两句写景，落日、黄河，气象宏大壮阔。后两句即景生情，蕴含深刻哲理：只有站得更高，才能看得更远。全诗气势磅礴，是唐代五绝中的压卷之作。", "作者": "王之渤（688年－742年），字季凌，唐代诗人。善写边塞诗，作品多已散殃，《凉州词》《登鹤雀楼》为其代表作。"}}, {"title": "相思", "poet": "王维", "dynasty": "唐", "type": "五言绝句", "theme": "爱情", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "秋夕", "poet": "杜牧", "dynasty": "唐", "type": "七言绝句", "theme": "七夕", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "秋思", "poet": "张籍", "dynasty": "唐", "type": "七言绝句", "theme": "思乡", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "秋日湖上", "poet": "薛莹", "dynasty": "唐", "type": "五言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": 