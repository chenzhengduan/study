{"grade": "01-幼儿园", "label": "幼儿园", "count": 79, "poems": [{"title": "一去二三里", "poet": "邵雍", "dynasty": "宋", "type": "五言绝句", "theme": "写景", "tags": ["写景", "数字", "启蒙"], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": ["一去二三里，", "烟村四五家。", "亭台六七座，", "八九十枝花。"], "ruby": [[["一", ""], ["去", "qù"], ["二", "èr"], ["三", "sān"], ["里", "lǐ"], ["，", ""]], [["烟", "yān"], ["村", "cūn"], ["四", "sì"], ["五", "wǔ"], ["家", "jiā"], ["。", ""]], [["亭", "tíng"], ["台", "tái"], ["六", "liù"], ["七", "qī"], ["座", "zuò"], ["，", ""]], [["八", "bā"], ["九", "jiǔ"], ["十", "shí"], ["枝", "zhī"], ["花", "huā"], ["。", ""]]], "sections": {"译文": "一眼望去二三里远，有炊烟的村庄四五户人家。亭台楼阁有六七座，还有八九十枝盛开的鲜花。", "注释": "- **去**：距离。\n- **里**：长度单位，一里约五百米。\n- **烟村**：炊烟袅袅的村庄。", "赏析": "这首诗将一到十的数字巧妙嵌入诗句，勾勒出一幅恬静的乡村春景图。语言清浅、画面感强，是儿童识字与数字启蒙的经典篇目，读来朗朗上口。", "作者": "邵雍（1011年－1077年），字尧夫，北宋理学家、诗人。其诗多平淡自然，富有理趣。"}}, {"title": "七步诗", "poet": "曹植", "dynasty": "三国", "type": "五言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "乌衣巷", "poet": "刘禹锡", "dynasty": "唐", "type": "七言绝句", "theme": "咏史", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "乐游原", "poet": "李商隐", "dynasty": "唐", "type": "五言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "农家", "poet": "颜仁郁", "dynasty": "唐", "type": "七言绝句", "theme": "民生", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "冬夜读书示子聿", "poet": "陆游", "dynasty": "宋", "type": "七言绝句", "theme": "学习", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "出师讨满夷自瓜州至金陵", "poet": "郑成功", "dynasty": "明", "type": "七言绝句", "theme": "爱国", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "剑客", "poet": "贾岛", "dynasty": "唐", "type": "五言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "劝学", "poet": "颜真卿", "dynasty": "唐", "type": "七言绝句", "theme": "学习", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "北风行", "poet": "刘基", "dynasty": "明", "type": "乐府诗", "theme": "战争", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "南园十三首（其五）", "poet": "李贺", "dynasty": "唐", "type": "七言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "古朗月行（节选）", "poet": "李白", "dynasty": "唐", "type": "五言古诗", "theme": "咏物", "tags": ["月亮", "童趣", "想象"], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": ["小时不识月，", "呼作白玉盘。", "又疑瑶台镜，", "飞在青云端。"], "ruby": [[["小", "xiǎo"], ["时", "shí"], ["不", "bù"], ["识", "shí"], ["月", "yuè"], ["，", ""]], [["呼", "hū"], ["作", "zuò"], ["白", "bái"], ["玉", "yù"], ["盘", "pán"], ["。", ""]], [["又", "yòu"], ["疑", "yí"], ["瑶", "yáo"], ["台", "tái"], ["镜", "jìng"], ["，", ""]], [["飞", "fēi"], ["在", "zài"], ["青", "qīng"], ["云", "yún"], ["端", "duān"], ["。", ""]]], "sections": {"译文": "小时候不认识月亮，把它称作白玉盘。又怀疑它是瑶台的仙镜，飞到了青云之上。", "注释": "- **呼作**：称为，叫作。\n- **瑶台**：传说中神仙居住的地方。\n- **青云端**：青天之上。", "赏析": "这是李白《古朗月行》的前四句，常作为小学课文节选。以儿童口吻写对月亮的好奇想象，\"白玉盘\"\"瑶台镜\"两个比喻新颖灵动，将月亮之圆之亮写得如在眼前，又充满童真童趣。", "作者": "李白（701年－762年），字太白，号青莲居士，唐代伟大的浪漫主义诗人，\"诗仙\"。"}}, {"title": "古朗月行（节选）", "poet": "李白", "dynasty": "唐", "type": "五言古诗", "theme": "咏物", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "同儿辈赋未开海棠（其一）", "poet": "元好问", "dynasty": "金", "type": "七言绝句", "theme": "哲理", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "咏柳", "poet": "曾巩", "dynasty": "宋", "type": "七言绝句", "theme": "咏物", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "咏鹅", "poet": "骆宾王", "dynasty": "唐", "type": "五言古诗", "theme": "咏物", "tags": ["咏物", "鹅", "儿童"], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": ["鹅鹅鹅，，，", "曲项向天歌。", "白毛浮绿水，", "红掌拨清波。"], "ruby": [[["鹅", "é"], ["鹅", "é"], ["鹅", "é"], ["，", ""], ["，", ""], ["，", ""]], [["曲", "qū"], ["项", "xiàng"], ["向", "xiàng"], ["天", "tiān"], ["歌", "gē"], ["。", ""]], [["白", "bái"], ["毛", "máo"], ["浮", "fú"], ["绿", "lǜ"], ["水", "shuǐ"], ["，", ""]], [["红", "hóng"], ["掌", "zhǎng"], ["拨", "bō"], ["清", "qīng"], ["波", "bō"], ["。", ""]]], "sections": {"译文": "白色的鹅啊鹅啊鹅，弯着脖子向天唱歌。\n雪白的羽毛浮在绿水上，红色的脚掌拨动清澈的水波。", "注释": "- **咏**：用诗词来描述，抒发。\n- **曲项**：弯着脖子。项，脖子。\n- **歌**：鸣叫。\n- **红掌**：红色的脚掌。\n- **拨**：划动。", "赏析": "这是骆宾王在七岁时写的一首诗，全诗用字简练，色彩鲜明，生动描绘了白鹅在水上嬉戏的情景。\"白毛\"对\"红掌\"，\"绿水\"对\"清波\"，色彩对比鲜明，充满童趣。", "作者": "骆宾王（约619年－约687年），字观光，唐代诗人。与王勃、杨炯、卢照邻并称\"初唐四杰\"。相传此诗为其七岁所作。"}}, {"title": "垓下歌", "poet": "项羽", "dynasty": "秦", "type": "乐府诗", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "塞外杂咏", "poet": "林则徐", "dynasty": "清", "type": "七言绝句", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "大风歌", "poet": "刘邦", "dynasty": "汉", "type": "乐府诗", "theme": "咏怀", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "客中初夏", "poet": "司马光", "dynasty": "宋", "type": "七言绝句", "theme"