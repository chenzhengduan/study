汗滴禾下土。", "谁知盘中餐，", "粒粒皆辛苦。"], "ruby": [[["锄", "chú"], ["禾", "hé"], ["日", "rì"], ["当", "dāng"], ["午", "wǔ"], ["，", ""]], [["汗", "hàn"], ["滴", "dī"], ["禾", "hé"], ["下", "xià"], ["土", "tǔ"], ["。", ""]], [["谁", "shuí"], ["知", "zhī"], ["盘", "pán"], ["中", "zhōng"], ["餐", "cān"], ["，", ""]], [["粒", "lì"], ["粒", "lì"], ["皆", "jiē"], ["辛", "xīn"], ["苦", "kǔ"], ["。", ""]]], "sections": {"译文": "农民在正午烈日下给禾苗锄草松土，汗水一滴滴落在禾苗下的泥土里。有谁知道我们盘中的饭食，每一粒都是农民辛苦劳动换来的。", "注释": "- **锄禾**：给禾苗锄草松土。\n- **日当午**：正午烈日当头。\n- **餐**：饭食。", "赏析": "这首诗语言浅白，却字字千钧。\"锄禾日当午，汗滴禾下土\"以白描手法写出农民劳作的艰辛，\"谁知盘中餐，粒粒皆辛苦\"则由景生情，告诫人们珍惜粮食。全诗对比鲜明，发人深省，是幼儿启蒙的名篇。", "作者": "李绅（772年－846年），字公垂，唐代诗人。与白居易、元稹交好，是新乐府运动的倡导者之一。其《悯农》二首传诵千古。"}}, {"title": "悯农（其二）", "poet": "李绅", "dynasty": "唐", "type": "五言绝句", "theme": "惜农", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "房兵曹胡马", "poet": "杜甫", "dynasty": "唐", "type": "五言律诗", "theme": "咏物", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "明日歌", "poet": "钱福", "dynasty": "明", "type": "乐府诗", "theme": "惜时", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "春日偶成", "poet": "程颢", "dynasty": "宋", "type": "七言绝句", "theme": "春天", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "望月怀远（节选）", "poet": "张九龄", "dynasty": "唐", "type": "五言律诗", "theme": "思念", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "江上", "poet": "王安石", "dynasty": "宋", "type": "五言绝句", "theme": "写景", "tags": [], "grade": "01-幼儿园", "grade_label": "幼儿园", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "江南逢李龟年", "poet": "杜甫", "dynast