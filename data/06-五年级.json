{"grade": "06-五年级", "label": "五年级", "count": 23, "poems": [{"title": "乞巧", "poet": "林杰", "dynasty": "唐", "type": "七言绝句", "theme": "七夕", "tags": ["七夕", "节日", "神话"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["七夕今宵看碧霄，", "牵牛织女渡河桥。", "家家乞巧望秋月，", "穿尽红丝几万条。"], "ruby": [[["七", "qī"], ["夕", "xī"], ["今", "jīn"], ["宵", "xiāo"], ["看", "kàn"], ["碧", "bì"], ["霄", "xiāo"], ["，", ""]], [["牵", "qiān"], ["牛", "niú"], ["织", "zhī"], ["女", "nǚ"], ["渡", "dù"], ["河", "hé"], ["桥", "qiáo"], ["。", ""]], [["家", "jiā"], ["家", "jiā"], ["乞", "qǐ"], ["巧", "qiǎo"], ["望", "wàng"], ["秋", "qiū"], ["月", "yuè"], ["，", ""]], [["穿", "chuān"], ["尽", "jǐn"], ["红", "hóng"], ["丝", "sī"], ["几", "jǐ"], ["万", "wàn"], ["条", "tiáo"], ["。", ""]]], "sections": {"译文": "今晚七夕看碧空，牵牛织女鹊桥相会。家家户户望月乞巧，穿过的红丝有几万条。", "注释": "- **乞巧**：七夕节女子向织女乞求巧手技艺的风俗。\n- **碧霄**：碧蓝天空。", "赏析": "此诗写七夕乞巧风俗，反映了人们对美好技艺和爱情的向往。", "作者": "林杰（831年－847年），唐代诗人，英年早逝。"}}, {"title": "乡村四月", "poet": "翁卷", "dynasty": "宋", "type": "七言绝句", "theme": "田园", "tags": ["田园", "农村", "夏天"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["绿遍山原白满川，", "子规声里雨如烟。", "乡村四月闲人少，", "才了蚕桑又插田。"], "ruby": [[["绿", "lǜ"], ["遍", "biàn"], ["山", "shān"], ["原", "yuán"], ["白", "bái"], ["满", "mǎn"], ["川", "chuān"], ["，", ""]], [["子", "zi"], ["规", "guī"], ["声", "shēng"], ["里", "lǐ"], ["雨", "yǔ"], ["如", "rú"], ["烟", "yān"], ["。", ""]], [["乡", "xiāng"], ["村", "cūn"], ["四", "sì"], ["月", "yuè"], ["闲", "xián"], ["人", "rén"], ["少", "shǎo"], ["，", ""]], [["才", "cái"], ["了", "le"], ["蚕", "cán"], ["桑", "sāng"], ["又", "yòu"], ["插", "chā"], ["田", "tián"], ["。", ""]]], "sections": {"译文": "山原碧绿满川白，杜鹃声里雨如烟。乡村四月闲人少，刚忙完蚕桑又去插田。", "注释": "- **子规**：杜鹃鸟。\n- **了**：结束。", "赏析": "此诗以清新笔调描绘江南初夏风光和农忙景象。", "作者": "翁卷（生卒年不详），南宋诗人，永嘉四灵之一。"}}, {"title": "从军行", "poet": "王昌龄", "dynasty": "唐", "type": "七言绝句", "theme": "边塞", "tags": ["边塞", "战争", "豪迈"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["青海长云暗雪山，", "孤城遥望玉门关。", "黄沙百战穿金甲，", "不破楼兰终不还。"], "ruby": [[["青", "qīng"], ["海", "hǎi"], ["长", "zhǎng"], ["云", "yún"], ["暗", "àn"], ["雪", "xuě"], ["山", "shān"], ["，", ""]], [["孤", "gū"], ["城", "chéng"], ["遥", "yáo"], ["望", "wàng"], ["玉", "yù"], ["门", "mén"], ["关", "guān"], ["。", ""]], [["黄", "huáng"], ["沙", "shā"], ["百", "bǎi"], ["战", "zhàn"], ["穿", "chuān"], ["金", "jīn"], ["甲", "jiǎ"], ["，", ""]], [["不", "bù"], ["破", "pò"], ["楼", "lóu"], ["兰", "lán"], ["终", "zhōng"], ["不", "bù"], ["还", "hái"], ["。", ""]]], "sections": {"译文": "青海乌云暗雪山，孤城遥望玉门关。黄沙百战磨穿金甲，不破楼兰绝不回家。", "注释": "- **穿**：磨破。\n- **楼兰**：西域古国，借指敌人。", "赏析": "边塞诗代表作。不破楼兰终不还直抒将士豪情壮志，慷慨激昂。", "作者": "王昌龄（约698年－约757年），字少伯，唐代诗人，七绝圣手。"}}, {"title": "凉州词（黄河远上）", "poet": "王之涣", "dynasty": "唐", "type": "七言绝句", "theme": "边塞", "tags": ["边塞", "思乡", "悲凉"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["黄河远上白云间，", "一片孤城万仞山。", "羌笛何须怨杨柳，", "春风不度玉门关。"], "ruby": [[["黄", "huáng"], ["河", "hé"], ["远", "yuǎn"], ["上", "shàng"], ["白", "bái"], ["云", "yún"], ["间", "jiān"], ["，", ""]], [["一", ""], ["片", "piàn"], ["孤", "gū"], ["城", "chéng"], ["万", "wàn"], ["仞", "rèn"], ["山", "shān"], ["。", ""]], [["羌", "qiāng"], ["笛", "dí"], ["何", "hé"], ["须", "xū"], ["怨", "yuàn"], ["杨", "yáng"], ["柳", "liǔ"], ["，", ""]], [["春", "chūn"], ["风", "fēng"], ["不", "bù"], ["度", "dù"], ["玉", "yù"], ["门", "mén"], ["关", "guān"], ["。", ""]]], "sections": {"译文": "黄河远上白云间，孤城矗立在万仞山中。羌笛何必怨杨柳，春风本来吹不到玉门关。", "注释": "- **羌笛**：羌族乐器。\n- **杨柳**：《折杨柳》曲。", "赏析": "以壮阔边塞之景开篇。羌笛何须怨杨柳以翻案笔法写出戍边的悲凉慷慨。", "作者": "王之涣（688年－742年），字季凌，唐代边塞诗人。"}}, {"title": "四时田园杂兴（其三十一）", "poet": "范成大", "dynasty": "宋", "type": "七言绝句", "theme": "田园", "tags": ["田园", "农村", "劳动"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["昼出耘田夜绩麻，", "村庄儿女各当家。", "童孙未解供耕织，", "也傍桑阴学种瓜。"], "ruby": [[["昼", "zhòu"], ["出", "chū"], ["耘", "yún"], ["田", "tián"], ["夜", "yè"], ["绩", "jì"], ["麻", "má"], ["，", ""]], [["村", "cūn"], ["庄", "zhuāng"], ["儿", "ér"], ["女", "nǚ"], ["各", "gè"], ["当", "dāng"], ["家", "jiā"], ["。", ""]], [["童", "tóng"], ["孙", "sūn"], ["未", "wèi"], ["解", "jiě"], ["供", "gōng"], ["耕", "gēng"], ["织", "zhī"], ["，", ""]], [["也", "yě"], ["傍", "bàng"], ["桑", "sāng"], ["阴", "yīn"], ["学", "xué"], ["种", "zhǒng"], ["瓜", "guā"], ["。", ""]]], "sections": {"译文": "白天耘田夜晚搓麻，村里男女各当家。小孙子不懂耕织也在桑树下学种瓜。", "注释": "- **耘田**：除草。\n- **绩麻**：把麻搓成线。", "赏析": "此诗描写农村夏日劳作景象。童孙学种瓜展现了勤劳淳朴的民风。", "作者": "范成大（1126年－1193年），号石湖居士，南宋诗人。"}}, {"title": "山居秋暝", "poet": "王维", "dynasty": "唐", "type": "五言律诗", "theme": "山水", "tags": ["山水", "秋天", "隐逸"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["空山新雨后，天气晚来秋。明月松间照，清泉石上流。竹喧归浣女，莲动下渔舟。随意春芳歇，王孙自可留。"], "ruby": [[["空", "kōng"], ["山", "shān"], ["新", "xīn"], ["雨", "yǔ"], ["后", "hòu"], ["，", ""], ["天", "tiān"], ["气", "qì"], ["晚", "wǎn"], ["来", "lái"], ["秋", "qiū"], ["。", ""], ["明", "míng"], ["月", "yuè"], ["松", "sōng"], ["间", "jiān"], ["照", "zhào"], ["，", ""], ["清", "qīng"], ["泉", "quán"], ["石", "shí"], ["上", "shàng"], ["流", "liú"], ["。", ""], ["竹", "zhú"], ["喧", "xuān"], ["归", "guī"], ["浣", "huàn"], ["女", "nǚ"], ["，", ""], ["莲", "lián"], ["动", "dòng"], ["下", "xià"], ["渔", "yú"], ["舟", "zhōu"], ["。", ""], ["随", "suí"], ["意", "yì"], ["春", "chūn"], ["芳", "fāng"], ["歇", "xiē"], ["，", ""], ["王", "wáng"], ["孙", "sūn"], ["自", "zì"], ["可", "kě"], ["留", "liú"], ["。", ""]]], "sections": {"译文": "空山新雨后天晚秋意浓。明月照松间清泉石上流。竹喧是浣女归，莲动是渔舟下。任凭春芳凋谢王孙可在此长留。", "注释": "- **暝**：黄昏。\n- **浣女**：洗衣女子。", "赏析": "王维山水名篇。明月松间照清泉石上流是写景名句，动静结合色声交融。表达归隐山林的心愿。", "作者": "王维（约701年－761年），字摩诘，唐代诗人、画家。"}}, {"title": "己亥杂诗", "poet": "龚自珍", "dynasty": "清", "type": "七言绝句", "theme": "爱国", "tags": ["爱国", "改革", "咏怀"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["浩荡离愁白日斜，", "吟鞭东指即天涯。", "落红不是无情物，", "化作春泥更护花。"], "ruby": [[["浩", "hào"], ["荡", "dàng"], ["离", "lí"], ["愁", "chóu"], ["白", "bái"], ["日", "rì"], ["斜", "xié"], ["，", ""]], [["吟", "yín"], ["鞭", "biān"], ["东", "dōng"], ["指", "zhǐ"], ["即", "jí"], ["天", "tiān"], ["涯", "yá"], ["。", ""]], [["落", "luò"], ["红", "hóng"], ["不", "bù"], ["是", "shì"], ["无", "wú"], ["情", "qíng"], ["物", "wù"], ["，", ""]], [["化", "huà"], ["作", "zuò"], ["春", "chūn"], ["泥", "ní"], ["更", "gèng"], ["护", "hù"], ["花", "huā"], ["。", ""]]], "sections": {"译文": "满离愁落日西斜，挥鞭东去便是天涯。落花不是无情物，化作春泥更护花。", "注释": "- **己亥**：清道光十九年（1839年）。\n- **落红**：落花。", "赏析": "以落红自喻，虽辞官仍愿为国效力。落红不是无情物，化作春泥更护花蕴含牺牲自我培育新力量的奉献精神。", "作者": "龚自珍（1792年－1841年），清代思想家、诗人，近代改良主义先驱。"}}, {"title": "村晚", "poet": "雷震", "dynasty": "宋", "type": "七言绝句", "theme": "田园", "tags": ["田园", "农村", "童趣"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["草满池塘水满陂，", "山衔落日浸寒漪。", "牧童归去横牛背，", "短笛无腔信口吹。"], "ruby": [[["草", "cǎo"], ["满", "mǎn"], ["池", "chí"], ["塘", "táng"], ["水", "shuǐ"], ["满", "mǎn"], ["陂", "bēi"], ["，", ""]], [["山", "shān"], ["衔", "xián"], ["落", "luò"], ["日", "rì"], ["浸", "jìn"], ["寒", "hán"], ["漪", "yī"], ["。", ""]], [["牧", "mù"], ["童", "tóng"], ["归", "guī"], ["去", "qù"], ["横", "héng"], ["牛", "niú"], ["背", "bèi"], ["，", ""]], [["短", "duǎn"], ["笛", "dí"], ["无", "wú"], ["腔", "qiāng"], ["信", "xìn"], ["口", "kǒu"], ["吹", "chuī"], ["。", ""]]], "sections": {"译文": "草满池水满堤，山衔落日浸寒波。牧童横坐牛背回家，短笛不成调随口吹。", "注释": "- **陂**：池塘堤岸。\n- **漪**：水波纹。", "赏析": "此诗描绘悠然自得的乡村晚归图。牧童横牛背信口吹笛自由自在跃然纸上。", "作者": "雷震（生卒年不详），宋代诗人。"}}, {"title": "杨氏之子", "poet": "刘义庆", "dynasty": "南朝", "type": "文言文", "theme": "智慧", "tags": ["智慧", "童趣", "文言文"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["梁国杨氏子九岁，甚聪惠。孔君平诣其父，父不在，乃呼儿出。为设果，果有杨梅。孔指以示儿曰：此是君家果。儿应声答曰：未闻孔雀是夫子家禽。"], "ruby": [[["梁", "liáng"], ["国", "guó"], ["杨", "yáng"], ["氏", "shì"], ["子", "zi"], ["九", "jiǔ"], ["岁", "suì"], ["，", ""], ["甚", "shèn"], ["聪", "cōng"], ["惠", "huì"], ["。", ""], ["孔", "kǒng"], ["君", "jūn"], ["平", "píng"], ["诣", "yì"], ["其", "qí"], ["父", "fù"], ["，", ""], ["父", "fù"], ["不", "bù"], ["在", "zài"], ["，", ""], ["乃", "nǎi"], ["呼", "hū"], ["儿", "ér"], ["出", "chū"], ["。", ""], ["为", "wèi"], ["设", "shè"], ["果", "guǒ"], ["，", ""], ["果", "guǒ"], ["有", "yǒu"], ["杨", "yáng"], ["梅", "méi"], ["。", ""], ["孔", "kǒng"], ["指", "zhǐ"], ["以", "yǐ"], ["示", "shì"], ["儿", "ér"], ["曰", "yuē"], ["：", ""], ["此", "cǐ"], ["是", "shì"], ["君", "jūn"], ["家", "jiā"], ["果", "guǒ"], ["。", ""], ["儿", "ér"], ["应", "yīng"], ["声", "shēng"], ["答", "dá"], ["曰", "yuē"], ["：", ""], ["未", "wèi"], ["闻", "wén"], ["孔", "kǒng"], ["雀", "què"], ["是", "shì"], ["夫", "fū"], ["子", "zi"], ["家", "jiā"], ["禽", "qín"], ["。", ""]]], "sections": {"译文": "梁国杨家九岁小孩很聪明。孔君平来访指着杨梅说这是你家果子。小孩应声说没听说孔雀是您家的鸟。", "注释": "- **诣**：拜访。\n- **夫子**：对对方的敬称。", "赏析": "以杨梅和杨姓开玩笑，孩子以孔雀和孔姓机智回击，妙趣横生。", "作者": "本文选自《世说新语·言语》。"}}, {"title": "枫桥夜泊", "poet": "张继", "dynasty": "唐", "type": "七言绝句", "theme": "秋夜", "tags": ["秋夜", "旅愁", "寺钟"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["月落乌啼霜满天，", "江枫渔火对愁眠。", "姑苏城外寒山寺，", "夜半钟声到客船。"], "ruby": [[["月", "yuè"], ["落", "luò"], ["乌", "wū"], ["啼", "tí"], ["霜", "shuāng"], ["满", "mǎn"], ["天", "tiān"], ["，", ""]], [["江", "jiāng"], ["枫", "fēng"], ["渔", "yú"], ["火", "huǒ"], ["对", "duì"], ["愁", "chóu"], ["眠", "mián"], ["。", ""]], [["姑", "gū"], ["苏", "sū"], ["城", "chéng"], ["外", "wài"], ["寒", "hán"], ["山", "shān"], ["寺", "sì"], ["，", ""]], [["夜", "yè"], ["半", "bàn"], ["钟", "zhōng"], ["声", "shēng"], ["到", "dào"], ["客", "kè"], ["船", "chuán"], ["。", ""]]], "sections": {"译文": "月亮落下，乌鸦啼叫，满天都是寒霜。江边的枫树和渔船上的灯火伴着我愁苦难眠。苏州城外的寒山寺，半夜里敲响的钟声传到了我停泊的客船上。", "注释": "- **枫桥**：在今江苏苏州西郊。\n- **乌啼**：乌鸦啼叫。\n- **江枫**：江边的枫树。\n- **渔火**：渔船上的灯火。\n- **姑苏**：苏州的别称。\n- **寒山寺**：苏州城西的一座古寺。", "赏析": "这首诗以秋夜之景写旅人之愁。前两句十四字写了月落、乌啼、霜天、江枫、渔火、愁眠六种意象，声色冷寂，烘托孤寂旅思。后两句以寒山寺夜半钟声作结，钟声悠悠传到客船，反衬夜之静、愁之深，余味无穷。", "作者": "张继（约715年－约779年），字懿孙，唐代诗人。其诗登第后仕途不显，《枫桥夜泊》一首传诵千古。"}}, {"title": "渔歌子", "poet": "张志和", "dynasty": "唐", "type": "词", "theme": "山水", "tags": ["山水", "隐逸", "词"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["西塞山前白鹭飞，", "桃花流水鳜鱼肥。", "青箬笠，绿蓑衣，", "斜风细雨不须归。"], "ruby": [[["西", "xī"], ["塞", "sāi"], ["山", "shān"], ["前", "qián"], ["白", "bái"], ["鹭", "lù"], ["飞", "fēi"], ["，", ""]], [["桃", "táo"], ["花", "huā"], ["流", "liú"], ["水", "shuǐ"], ["鳜", "guì"], ["鱼", "yú"], ["肥", "féi"], ["。", ""]], [["青", "qīng"], ["箬", "ruò"], ["笠", "lì"], ["，", ""], ["绿", "lǜ"], ["蓑", "suō"], ["衣", "yī"], ["，", ""]], [["斜", "xié"], ["风", "fēng"], ["细", "xì"], ["雨", "yǔ"], ["不", "bù"], ["须", "xū"], ["归", "guī"], ["。", ""]]], "sections": {"译文": "西塞山前白鹭飞，桃花流水鳜鱼肥。渔翁戴箬笠披蓑衣，斜风细雨中不须回家。", "注释": "- **西塞山**：在今浙江湖州。\n- **鳜鱼**：一种味道鲜美的鱼。", "赏析": "此词以清新明丽的笔触描绘江南水乡春日美景。斜风细雨不须归体现了隐逸的超然。", "作者": "张志和（约730年－约810年），字子同，唐代诗人，自号烟波钓徒。"}}, {"title": "游子吟", "poet": "孟郊", "dynasty": "唐", "type": "五言古诗", "theme": "母爱", "tags": ["母爱", "亲情", "游子"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["慈母手中线，", "游子身上衣。", "临行密密缝，", "意恐迟迟归。", "谁言寸草心，", "报得三春晖。"], "ruby": [[["慈", "cí"], ["母", "mǔ"], ["手", "shǒu"], ["中", "zhōng"], ["线", "xiàn"], ["，", ""]], [["游", "yóu"], ["子", "zǐ"], ["身", "shēn"], ["上", "shàng"], ["衣", "yī"], ["。", ""]], [["临", "lín"], ["行", "xíng"], ["密", "mì"], ["密", "mì"], ["缝", "féng"], ["，", ""]], [["意", "yì"], ["恐", "kǒng"], ["迟", "chí"], ["迟", "chí"], ["归", "guī"], ["。", ""]], [["谁", "shuí"], ["言", "yán"], ["寸", "cùn"], ["草", "cǎo"], ["心", "xīn"], ["，", ""]], [["报", "bào"], ["得", "dé"], ["三", "sān"], ["春", "chūn"], ["晖", "huī"], ["。", ""]]], "sections": {"译文": "慈母手中的针线，缝制出游子身上穿的衣服。临行前密密地缝制，生怕孩子迟迟不归。谁说小草那一点嫩心，能报答得了春天阳光般的恩情呢？", "注释": "- **游子**：离家远行的人。\n- **临行**：即将出发。\n- **意恐**：心里担心。\n- **寸草**：小草，比喻微小的子女。\n- **三春晖**：春天阳光，比喻母爱。三春，春季三个月。", "赏析": "前四句白描母亲为游子缝衣的情景，\"密密缝\"细节传神，\"意恐迟迟归\"写出母亲深情。后两句以\"寸草心\"对\"三春晖\"作比，化深恩为形象，问句收束，情感深沉。此诗成为歌颂母爱的千古名篇。", "作者": "孟郊（751年－814年），字东野，唐代诗人。其诗多写贫苦与亲情，风格质朴深沉。"}}, {"title": "示儿", "poet": "陆游", "dynasty": "宋", "type": "七言绝句", "theme": "爱国", "tags": ["爱国", "遗愿", "收复"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["死去元知万事空，", "但悲不见九州同。", "王师北定中原日，", "家祭无忘告乃翁。"], "ruby": [[["死", "sǐ"], ["去", "qù"], ["元", "yuán"], ["知", "zhī"], ["万", "wàn"], ["事", "shì"], ["空", "kōng"], ["，", ""]], [["但", "dàn"], ["悲", "bēi"], ["不", "bù"], ["见", "jiàn"], ["九", "jiǔ"], ["州", "zhōu"], ["同", "tóng"], ["。", ""]], [["王", "wáng"], ["师", "shī"], ["北", "běi"], ["定", "dìng"], ["中", "zhōng"], ["原", "yuán"], ["日", "rì"], ["，", ""]], [["家", "jiā"], ["祭", "jì"], ["无", "wú"], ["忘", "wàng"], ["告", "gào"], ["乃", "nǎi"], ["翁", "wēng"], ["。", ""]]], "sections": {"译文": "本来就知道人死后万事皆空，只是悲叹没能看到祖国山河统一。当朝廷大军北伐收复中原的那一天，举行家祭时千万别忘了告诉你们的父亲。", "注释": "- **示**：告诉，嘱咐。\n- **元知**：本来就知道。元，同\"原\"。\n- **九州**：指全中国。\n- **同**：统一。\n- **王师**：指南宋朝廷的军队。\n- **家祭**：家中祭祀祖先。\n- **乃翁**：你们的父亲。乃，你的。翁，父亲。", "赏析": "这是陆游的绝笔诗，也是他最感人的爱国名篇。开篇\"死去元知万事空\"以生死之大观入笔，却\"但悲不见九州同\"——唯一放不下的就是国家未统一。后两句托付子辈，盼中原收复之日不忘告知，爱国之情至死不渝，沉痛而激昂。", "作者": "陆游（1125年－1210年），字务观，号放翁，南宋伟大的爱国诗人。一生创作诗歌近万首，抒发抗金复国之志，风格悲壮雄迈。"}}, {"title": "秋夜将晓出篱门迎凉有感", "poet": "陆游", "dynasty": "宋", "type": "七言绝句", "theme": "爱国", "tags": ["爱国", "咏怀", "南宋"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["三万里河东入海，", "五千仞岳上摩天。", "遗民泪尽胡尘里，", "南望王师又一年。"], "ruby": [[["三", "sān"], ["万", "wàn"], ["里", "lǐ"], ["河", "hé"], ["东", "dōng"], ["入", "rù"], ["海", "hǎi"], ["，", ""]], [["五", "wǔ"], ["千", "qiān"], ["仞", "rèn"], ["岳", "yuè"], ["上", "shàng"], ["摩", "mó"], ["天", "tiān"], ["。", ""]], [["遗", "yí"], ["民", "mín"], ["泪", "lèi"], ["尽", "jǐn"], ["胡", "hú"], ["尘", "chén"], ["里", "lǐ"], ["，", ""]], [["南", "nán"], ["望", "wàng"], ["王", "wáng"], ["师", "shī"], ["又", "yòu"], ["一", ""], ["年", "nián"], ["。", ""]]], "sections": {"译文": "三万里黄河东入海，五千仞华山高摩天。遗民泪尽在胡尘里，南望朝廷军队又过了一年。", "注释": "- **遗民**：金人统治下的宋民。\n- **王师**：南宋朝廷的军队。", "赏析": "以壮丽山河与沉痛遗民对比。南望王师又一年一个又字道尽年复一年的失望与期盼。", "作者": "陆游（1125年－1210年），字务观，号放翁，南宋伟大的爱国诗人。"}}, {"title": "稚子弄冰", "poet": "杨万里", "dynasty": "宋", "type": "七言绝句", "theme": "童趣", "tags": ["童趣", "冬天", "儿童"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["稚子金盆脱晓冰，", "彩丝穿取当银钲。", "敲成玉磬穿林响，", "忽作玻璃碎地声。"], "ruby": [[["稚", "zhì"], ["子", "zi"], ["金", "jīn"], ["盆", "pén"], ["脱", "tuō"], ["晓", "xiǎo"], ["冰", "bīng"], ["，", ""]], [["彩", "cǎi"], ["丝", "sī"], ["穿", "chuān"], ["取", "qǔ"], ["当", "dāng"], ["银", "yín"], ["钲", "zhēng"], ["。", ""]], [["敲", "qiāo"], ["成", "chéng"], ["玉", "yù"], ["磬", "qìng"], ["穿", "chuān"], ["林", "lín"], ["响", "xiǎng"], ["，", ""]], [["忽", "hū"], ["作", "zuò"], ["玻", "bō"], ["璃", "lí"], ["碎", "suì"], ["地", "dì"], ["声", "shēng"], ["。", ""]]], "sections": {"译文": "小孩早上把盆里的冰取下来，用彩丝穿上当银钲敲。敲出玉磬声穿林响，忽然冰块碎地作响。", "注释": "- **银钲**：打击乐器。\n- **玻璃**：天然水晶。", "赏析": "此诗写儿童冬日玩冰的乐趣，充满生活气息和童心童趣。", "作者": "杨万里（1127年－1206年），字廷秀，号诚斋，南宋诗人。"}}, {"title": "自相矛盾", "poet": "韩非子", "dynasty": "战国", "type": "文言文", "theme": "寓言", "tags": ["寓言", "哲理", "文言文"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["楚人有鬻盾与矛者，誉之曰：吾盾之坚，莫能陷也。又誉其矛曰：吾矛之利，于物无不陷也。或曰：以子之矛陷子之盾，何如？其人弗能应也。"], "ruby": [[["楚", "chǔ"], ["人", "rén"], ["有", "yǒu"], ["鬻", "yù"], ["盾", "dùn"], ["与", "yǔ"], ["矛", "máo"], ["者", "zhě"], ["，", ""], ["誉", "yù"], ["之", "zhī"], ["曰", "yuē"], ["：", ""], ["吾", "wú"], ["盾", "dùn"], ["之", "zhī"], ["坚", "jiān"], ["，", ""], ["莫", "mò"], ["能", "néng"], ["陷", "xiàn"], ["也", "yě"], ["。", ""], ["又", "yòu"], ["誉", "yù"], ["其", "qí"], ["矛", "máo"], ["曰", "yuē"], ["：", ""], ["吾", "wú"], ["矛", "máo"], ["之", "zhī"], ["利", "lì"], ["，", ""], ["于", "yú"], ["物", "wù"], ["无", "wú"], ["不", "bù"], ["陷", "xiàn"], ["也", "yě"], ["。", ""], ["或", "huò"], ["曰", "yuē"], ["：", ""], ["以", "yǐ"], ["子", "zi"], ["之", "zhī"], ["矛", "máo"], ["陷", "xiàn"], ["子", "zi"], ["之", "zhī"], ["盾", "dùn"], ["，", ""], ["何", "hé"], ["如", "rú"], ["？", ""], ["其", "qí"], ["人", "rén"], ["弗", "fú"], ["能", "néng"], ["应", "yīng"], ["也", "yě"], ["。", ""]]], "sections": {"译文": "楚国卖盾和矛的人夸盾最坚固矛最锋利。有人问用你的矛刺你的盾会怎样？那人无法回答。", "注释": "- **鬻**：卖。\n- **陷**：刺穿。\n- **弗**：不。", "赏析": "这篇寓言讽刺言行自相矛盾的人。自相矛盾成为成语比喻前后抵触。", "作者": "韩非子（约前280年－前233年），战国末期法家代表人物。"}}, {"title": "观书有感二首（其一）", "poet": "朱熹", "dynasty": "宋", "type": "七言绝句", "theme": "哲理", "tags": ["哲理", "读书", "学习"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["半亩方塘一鉴开，", "天光云影共徘徊。", "问渠那得清如许？", "为有源头活水来。"], "ruby": [[["半", "bàn"], ["亩", "mǔ"], ["方", "fāng"], ["塘", "táng"], ["一", ""], ["鉴", "jiàn"], ["开", "kāi"], ["，", ""]], [["天", "tiān"], ["光", "guāng"], ["云", "yún"], ["影", "yǐng"], ["共", "gòng"], ["徘", "pái"], ["徊", "huái"], ["。", ""]], [["问", "wèn"], ["渠", "qú"], ["那", "nà"], ["得", "dé"], ["清", "qīng"], ["如", "rú"], ["许", "xǔ"], ["？", ""]], [["为", "wèi"], ["有", "yǒu"], ["源", "yuán"], ["头", "tóu"], ["活", "huó"], ["水", "shuǐ"], ["来", "lái"], ["。", ""]]], "sections": {"译文": "半亩方塘像镜子一样打开，天光云影在水面徘徊。问它为什么这样清澈？因为有源头活水不断流来。", "注释": "- **鉴**：镜子。\n- **渠**：它。\n- **那得**：怎么会。", "赏析": "以方塘喻心智以活水喻新知。只有不断学习才能保持思想澄澈，为有源头活水来成为鼓励读书的名句。", "作者": "朱熹（1130年－1200年），字元晦，号晦庵，南宋理学家。"}}, {"title": "观书有感二首（其二）", "poet": "朱熹", "dynasty": "宋", "type": "七言绝句", "theme": "哲理", "tags": ["哲理", "读书", "学习"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["昨夜江边春水生，", "艨艟巨舰一毛轻。", "向来枉费推移力，", "此日中流自在行。"], "ruby": [[["昨", "zuó"], ["夜", "yè"], ["江", "jiāng"], ["边", "biān"], ["春", "chūn"], ["水", "shuǐ"], ["生", "shēng"], ["，", ""]], [["艨", "méng"], ["艟", "chōng"], ["巨", "jù"], ["舰", "jiàn"], ["一", ""], ["毛", "máo"], ["轻", "qīng"], ["。", ""]], [["向", "xiàng"], ["来", "lái"], ["枉", "wǎng"], ["费", "fèi"], ["推", "tuī"], ["移", "yí"], ["力", "lì"], ["，", ""]], [["此", "cǐ"], ["日", "rì"], ["中", "zhōng"], ["流", "liú"], ["自", "zì"], ["在", "zài"], ["行", "xíng"], ["。", ""]]], "sections": {"译文": "昨夜江边春水大涨，巨舰像羽毛一样轻飘。以前白费推移力气，今天在江心自在航行。", "注释": "- **艨艟**：古代大型战船。\n- **一毛轻**：像羽毛一样轻。", "赏析": "以行舟喻读书。春水生喻知识积累后的豁然贯通，强调厚积薄发之理。", "作者": "朱熹（1130年－1200年），字元晦，号晦庵，南宋理学家。"}}, {"title": "送元二使安西", "poet": "王维", "dynasty": "唐", "type": "七言绝句", "theme": "送别", "tags": ["送别", "友情", "边塞"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["渭城朝雨浥轻尘，", "客舍青青柳色新。", "劝君更尽一杯酒，", "西出阳关无故人。"], "ruby": [[["渭", "wèi"], ["城", "chéng"], ["朝", "cháo"], ["雨", "yǔ"], ["浥", "yì"], ["轻", "qīng"], ["尘", "chén"], ["，", ""]], [["客", "kè"], ["舍", "shě"], ["青", "qīng"], ["青", "qīng"], ["柳", "liǔ"], ["色", "sè"], ["新", "xīn"], ["。", ""]], [["劝", "quàn"], ["君", "jūn"], ["更", "gèng"], ["尽", "jǐn"], ["一", ""], ["杯", "bēi"], ["酒", "jiǔ"], ["，", ""]], [["西", "xī"], ["出", "chū"], ["阳", "yáng"], ["关", "guān"], ["无", "wú"], ["故", "gù"], ["人", "rén"], ["。", ""]]], "sections": {"译文": "渭城晨雨润湿轻尘，客舍柳色青翠新鲜。劝你再饮一杯酒，西出阳关没有老朋友了。", "注释": "- **浥**：湿润。\n- **阳关**：通往西域的重要关隘。", "赏析": "唐代最著名的送别诗之一。西出阳关无故人道尽远行孤寂和友情珍贵。", "作者": "王维（约701年－761年），字摩诘，唐代诗人、画家。"}}, {"title": "长相思", "poet": "纳兰性德", "dynasty": "清", "type": "词", "theme": "思乡", "tags": ["思乡", "边塞", "词"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["山一程，水一程，", "身向榆关那畔行，", "夜深千帐灯。", "风一更，雪一更，", "聒碎乡心梦不成，", "故园无此声。"], "ruby": [[["山", "shān"], ["一", ""], ["程", "chéng"], ["，", ""], ["水", "shuǐ"], ["一", ""], ["程", "chéng"], ["，", ""]], [["身", "shēn"], ["向", ""], ["榆", "yú"], ["关", "guān"], ["那", ""], ["畔", "pàn"], ["行", "xíng"], ["，", ""]], [["夜", "yè"], ["深", ""], ["千", "qiān"], ["帐", "zhàng"], ["灯", "dēng"], ["。", ""]], [["风", "fēng"], ["一", ""], ["更", "gēng"], ["，", ""], ["雪", "xuě"], ["一", ""], ["更", "gēng"], ["，", ""]], [["聒", "guō"], ["碎", ""], ["乡", "xiāng"], ["心", "xīn"], ["梦", "mèng"], ["不", ""], ["成", "chéng"], ["，", ""]], [["故", "gù"], ["园", ""], ["无", "wú"], ["此", ""], ["声", "shēng"], ["。", ""]]], "sections": {"译文": "翻过一程山，涉过一程水，我向山海关那边远行。深夜里千万顶帐篷里灯火通明。刮了一更风，又下一更雪，嘈杂的声音搅碎了思乡之心，连梦都做不成。家乡的园子里，可没有这样的风雪声。", "注释": "- **榆关**：山海关。\n- **那畔**：那边，指关外。\n- **千帐灯**：形容军营帐篷多，灯火也多。\n- **更**：旧时夜间计时单位，一夜分五更。\n- **聒**：声音吵闹。\n- **故园**：故乡的家园。", "赏析": "上阕写旅途跋涉与夜宿军营的壮阔景象，\"千帐灯\"三字气象宏远。下阕转写思乡，风雪交加，乡梦不成，以\"故园无此声\"一句作结——家乡的宁静与此地的风雪相对，思乡之情婉转深沉。此词以白描手法抒真情，被誉为纳兰词中的代表。", "作者": "纳兰性德（1655年－1685年），字容若，号楞伽山人，清代著名词人。其词真挚自然，风格近南唐李煜。"}}, {"title": "题临安邸", "poet": "林升", "dynasty": "宋", "type": "七言绝句", "theme": "爱国", "tags": ["爱国", "讽刺", "南宋"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["山外青山楼外楼，", "西湖歌舞几时休？", "暖风熏得游人醉，", "直把杭州作汴州。"], "ruby": [[["山", "shān"], ["外", "wài"], ["青", "qīng"], ["山", "shān"], ["楼", "lóu"], ["外", "wài"], ["楼", "lóu"], ["，", ""]], [["西", "xī"], ["湖", "hú"], ["歌", "gē"], ["舞", "wǔ"], ["几", "jǐ"], ["时", "shí"], ["休", "xiū"], ["？", ""]], [["暖", "nuǎn"], ["风", "fēng"], ["熏", "xūn"], ["得", "dé"], ["游", "yóu"], ["人", "rén"], ["醉", "zuì"], ["，", ""]], [["直", "zhí"], ["把", "bǎ"], ["杭", "háng"], ["州", "zhōu"], ["作", "zuò"], ["汴", "biàn"], ["州", "zhōu"], ["。", ""]]], "sections": {"译文": "青山之外有青山高楼之外有高楼，西湖歌舞几时才能停止？暖风把游人吹醉，简直把杭州当成了汴州。", "注释": "- **临安**：南宋都城杭州。\n- **汴州**：开封，北宋都城。", "赏析": "此诗辛辣讽刺南宋统治者苟且偷安。暖风熏得游人醉，直把杭州作汴州入木三分。", "作者": "林升（生卒年不详），南宋诗人，仅此一首诗传世。"}}, {"title": "鸟鸣涧", "poet": "王维", "dynasty": "唐", "type": "五言绝句", "theme": "山水", "tags": ["山水", "春天", "宁静"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["人闲桂花落，", "夜静春山空。", "月出惊山鸟，", "时鸣春涧中。"], "ruby": [[["人", "rén"], ["闲", "xián"], ["桂", "guì"], ["花", "huā"], ["落", "luò"], ["，", ""]], [["夜", "yè"], ["静", "jìng"], ["春", "chūn"], ["山", "shān"], ["空", "kōng"], ["。", ""]], [["月", "yuè"], ["出", "chū"], ["惊", "jīng"], ["山", "shān"], ["鸟", "niǎo"], ["，", ""]], [["时", "shí"], ["鸣", "míng"], ["春", "chūn"], ["涧", "jiàn"], ["中", "zhōng"], ["。", ""]]], "sections": {"译文": "人闲桂花飘落，夜静春山空寂。月亮惊动山鸟，时而在春涧中鸣叫。", "注释": "- **涧**：山沟。\n- **时鸣**：不时地鸣叫。", "赏析": "此诗以动写静以声衬静。月出惊山鸟以光与声打破静谧更显春山之幽静。", "作者": "王维（约701年－761年），字摩诘，唐代诗人、画家。"}}, {"title": "黄鹤楼送孟浩然之广陵", "poet": "李白", "dynasty": "唐", "type": "七言绝句", "theme": "送别", "tags": ["送别", "友情", "长江"], "grade": "06-五年级", "grade_label": "五年级", "lines": ["故人西辞黄鹤楼，", "烟花三月下扬州。", "孤帆远影碧空尽，", "唯见长江天际流。"], "ruby": [[["故", "gù"], ["人", "rén"], ["西", "xī"], ["辞", "cí"], ["黄", "huáng"], ["鹤", "hè"], ["楼", "lóu"], ["，", ""]], [["烟", "yān"], ["花", "huā"], ["三", "sān"], ["月", "yuè"], ["下", "xià"], ["扬", "yáng"], ["州", "zhōu"], ["。", ""]], [["孤", "gū"], ["帆", "fān"], ["远", "yuǎn"], ["影", "yǐng"], ["碧", "bì"], ["空", "kōng"], ["尽", "jǐn"], ["，", ""]], [["唯", "wéi"], ["见", "jiàn"], ["长", "zhǎng"], ["江", "jiāng"], ["天", "tiān"], ["际", "jì"], ["流", "liú"], ["。", ""]]], "sections": {"译文": "老朋友在黄鹤楼告别，在繁花三月去扬州。孤帆远影消失在碧空，只看见长江天际奔流。", "注释": "- **之**：去。\n- **广陵**：扬州。\n- **烟花**：繁花似锦的春景。", "赏析": "此诗写送别之情感情真挚而不哀伤。孤帆远影长江天际流以景写情，意境开阔情深意长。", "作者": "李白（701年－762年），字太白，号青莲居士，唐代伟大的浪漫主义诗人。"}}]}