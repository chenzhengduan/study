{"grade": "07-六年级", "label": "六年级", "count": 28, "poems": [{"title": "两小儿辩日", "poet": "列子", "dynasty": "战国", "type": "文言文", "theme": "智慧", "tags": ["智慧", "哲理", "文言文"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["孔子东游，见两小儿辩斗，问其故。一儿曰：我以日始出时去人近，而日中时远也。一儿曰：我以日初出远，而日中时近也。孔子不能决也。两小儿笑曰：孰为汝多知乎？"], "ruby": [[["孔", "kǒng"], ["子", "zi"], ["东", "dōng"], ["游", "yóu"], ["，", ""], ["见", "jiàn"], ["两", "liǎng"], ["小", "xiǎo"], ["儿", "ér"], ["辩", "biàn"], ["斗", "dòu"], ["，", ""], ["问", "wèn"], ["其", "qí"], ["故", "gù"], ["。", ""], ["一", ""], ["儿", "ér"], ["曰", "yuē"], ["：", ""], ["我", "wǒ"], ["以", "yǐ"], ["日", "rì"], ["始", "shǐ"], ["出", "chū"], ["时", "shí"], ["去", "qù"], ["人", "rén"], ["近", "jìn"], ["，", ""], ["而", "ér"], ["日", "rì"], ["中", "zhōng"], ["时", "shí"], ["远", "yuǎn"], ["也", "yě"], ["。", ""], ["一", ""], ["儿", "ér"], ["曰", "yuē"], ["：", ""], ["我", "wǒ"], ["以", "yǐ"], ["日", "rì"], ["初", "chū"], ["出", "chū"], ["远", "yuǎn"], ["，", ""], ["而", "ér"], ["日", "rì"], ["中", "zhōng"], ["时", "shí"], ["近", "jìn"], ["也", "yě"], ["。", ""], ["孔", "kǒng"], ["子", "zi"], ["不", "bù"], ["能", "néng"], ["决", "jué"], ["也", "yě"], ["。", ""], ["两", "liǎng"], ["小", "xiǎo"], ["儿", "ér"], ["笑", "xiào"], ["曰", "yuē"], ["：", ""], ["孰", "shú"], ["为", "wèi"], ["汝", "rǔ"], ["多", "duō"], ["知", "zhī"], ["乎", "hū"], ["？", ""]]], "sections": {"译文": "孔子东游见两小孩争辩。一个说太阳刚出时离人近中午时远。另一个说太阳刚出时远中午时近。孔子不能判断。小孩笑说谁说你知识渊博呢？", "注释": "- **辩斗**：争辩。\n- **去**：距离。\n- **孰**：谁。\n- **汝**：你。", "赏析": "两小儿辩日体现古人探索自然的精神。孔子不能决展示了实事求是的态度。", "作者": "本文选自《列子·汤问》。"}}, {"title": "书湖阴先生壁", "poet": "王安石", "dynasty": "宋", "type": "七言绝句", "theme": "田园", "tags": ["田园", "写景", "隐逸"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["茅檐长扫净无苔，", "花木成畦手自栽。", "一水护田将绿绕，", "两山排闼送青来。"], "ruby": [[["茅", "máo"], ["檐", "yán"], ["长", "cháng"], ["扫", "sǎo"], ["净", "jìng"], ["无", "wú"], ["苔", "tái"], ["，", ""]], [["花", "huā"], ["木", "mù"], ["成", "chéng"], ["畦", "qí"], ["手", "shǒu"], ["自", "zì"], ["栽", "zāi"], ["。", ""]], [["一", ""], ["水", "shuǐ"], ["护", "hù"], ["田", "tián"], ["将", "jiāng"], ["绿", "lǜ"], ["绕", "rào"], ["，", ""]], [["两", "liǎng"], ["山", "shān"], ["排", "pái"], ["闼", "tà"], ["送", "sòng"], ["青", "qīng"], ["来", "lái"], ["。", ""]]], "sections": {"译文": "茅檐常扫净无苔，花木成畦手自栽。一水护田绕绿，两山推门送青来。", "注释": "- **长扫**：经常打扫。\n- **排闼**：推开门。", "赏析": "一水护田将绿绕，两山排闼送青来以拟人手法写山水，赋予自然以人的情态。", "作者": "王安石（1021年－1086年），字介甫，号半山，北宋政治家。"}}, {"title": "伯牙鼓琴", "poet": "《吕氏春秋》", "dynasty": "战国", "type": "文言文", "theme": "知音", "tags": ["知音", "友情", "文言文"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["伯牙鼓琴，钟子期听之。方鼓琴而志在太山，钟子期曰：善哉乎鼓琴，巍巍乎若太山！少选之间而志在流水，钟子期又曰：善哉乎鼓琴，汤汤乎若流水。钟子期死，伯牙破琴绝弦，终身不复鼓琴。"], "ruby": [[["伯", "bó"], ["牙", "yá"], ["鼓", "gǔ"], ["琴", "qín"], ["，", ""], ["钟", "zhōng"], ["子", "zi"], ["期", "qī"], ["听", "tīng"], ["之", "zhī"], ["。", ""], ["方", "fāng"], ["鼓", "gǔ"], ["琴", "qín"], ["而", "ér"], ["志", "zhì"], ["在", "zài"], ["太", "tài"], ["山", "shān"], ["，", ""], ["钟", "zhōng"], ["子", "zi"], ["期", "qī"], ["曰", "yuē"], ["：", ""], ["善", "shàn"], ["哉", "zāi"], ["乎", "hū"], ["鼓", "gǔ"], ["琴", "qín"], ["，", ""], ["巍", "wēi"], ["巍", "wēi"], ["乎", "hū"], ["若", "ruò"], ["太", "tài"], ["山", "shān"], ["！", ""], ["少", "shǎo"], ["选", "xuǎn"], ["之", "zhī"], ["间", "jiān"], ["而", "ér"], ["志", "zhì"], ["在", "zài"], ["流", "liú"], ["水", "shuǐ"], ["，", ""], ["钟", "zhōng"], ["子", "zi"], ["期", "qī"], ["又", "yòu"], ["曰", "yuē"], ["：", ""], ["善", "shàn"], ["哉", "zāi"], ["乎", "hū"], ["鼓", "gǔ"], ["琴", "qín"], ["，", ""], ["汤", "tāng"], ["汤", "tāng"], ["乎", "hū"], ["若", "ruò"], ["流", "liú"], ["水", "shuǐ"], ["。", ""], ["钟", "zhōng"], ["子", "zi"], ["期", "qī"], ["死", "sǐ"], ["，", ""], ["伯", "bó"], ["牙", "yá"], ["破", "pò"], ["琴", "qín"], ["绝", "jué"], ["弦", "xián"], ["，", ""], ["终", "zhōng"], ["身", "shēn"], ["不", "bù"], ["复", "fù"], ["鼓", "gǔ"], ["琴", "qín"], ["。", ""]]], "sections": {"译文": "伯牙弹琴钟子期听。伯牙志在太山子期说像泰山。志在流月子期说像江河。子期死后伯牙破琴绝弦终身不再弹琴。", "注释": "- **鼓**：弹奏。\n- **少选**：一会儿。\n- **汤汤**：水势浩大。", "赏析": "伯牙绝弦是知音的经典典故。破琴绝弦体现了知音难觅的孤独与至深情谊。", "作者": "本文选自《吕氏春秋·本味》。"}}, {"title": "六月二十七日望湖楼醉书", "poet": "苏轼", "dynasty": "宋", "type": "七言绝句", "theme": "西湖", "tags": ["写景", "西湖", "暴雨"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["黑云翻墨未遮山，", "白雨跳珠乱入船。", "卷地风来忽吹散，", "望湖楼下水如天。"], "ruby": [[["黑", "hēi"], ["云", "yún"], ["翻", "fān"], ["墨", "mò"], ["未", "wèi"], ["遮", "zhē"], ["山", "shān"], ["，", ""]], [["白", "bái"], ["雨", "yǔ"], ["跳", "tiào"], ["珠", "zhū"], ["乱", "luàn"], ["入", "rù"], ["船", "chuán"], ["。", ""]], [["卷", "juǎn"], ["地", "dì"], ["风", "fēng"], ["来", "lái"], ["忽", "hū"], ["吹", "chuī"], ["散", "sàn"], ["，", ""]], [["望", "wàng"], ["湖", "hú"], ["楼", "lóu"], ["下", "xià"], ["水", "shuǐ"], ["如", "rú"], ["天", "tiān"], ["。", ""]]], "sections": {"译文": "黑云翻墨未遮山，白雨跳珠乱入船。卷地风来忽吹散，望湖楼下水如天。", "注释": "- **翻墨**：打翻的墨汁。\n- **跳珠**：跳动的珍珠。", "赏析": "此诗写西湖夏日暴雨骤来骤去的景象。短短四句写出天气剧变的全过程，笔力雄健。", "作者": "苏轼（1037年－1101年），字子瞻，号东坡居士，北宋文学家。"}}, {"title": "十五夜望月", "poet": "王建", "dynasty": "唐", "type": "七言绝句", "theme": "中秋", "tags": ["中秋", "思乡", "月亮"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["中庭地白树栖鸦，", "冷露无声湿桂花。", "今夜月明人尽望，", "不知秋思落谁家。"], "ruby": [[["中", "zhōng"], ["庭", "tíng"], ["地", "dì"], ["白", "bái"], ["树", "shù"], ["栖", "qī"], ["鸦", "yā"], ["，", ""]], [["冷", "lěng"], ["露", "lù"], ["无", "wú"], ["声", "shēng"], ["湿", "shī"], ["桂", "guì"], ["花", "huā"], ["。", ""]], [["今", "jīn"], ["夜", "yè"], ["月", "yuè"], ["明", "míng"], ["人", "rén"], ["尽", "jǐn"], ["望", "wàng"], ["，", ""]], [["不", "bù"], ["知", "zhī"], ["秋", "qiū"], ["思", "sī"], ["落", "luò"], ["谁", "shuí"], ["家", "jiā"], ["。", ""]]], "sections": {"译文": "中庭地白树栖鸦，冷露无声湿桂花。今夜月明人尽望，不知秋思落谁家。", "注释": "- **中庭**：庭院中。\n- **秋思**：秋日里的思念。", "赏析": "今夜月明人尽望，不知秋思落谁家由己及人，将思乡之情扩展到天下游子。", "作者": "王建（约767年－约830年），字仲初，唐代诗人。"}}, {"title": "卜算子·送鲍浩然之浙东", "poet": "王观", "dynasty": "宋", "type": "词", "theme": "送别", "tags": ["送别", "词", "友情"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["水是眼波横，山是眉峰聚。欲问行人去那边？眉眼盈盈处。才始送春归，又送君归去。若到江南赶上春，千万和春住。"], "ruby": [[["水", "shuǐ"], ["是", "shì"], ["眼", "yǎn"], ["波", "bō"], ["横", "héng"], ["，", ""], ["山", "shān"], ["是", "shì"], ["眉", "méi"], ["峰", "fēng"], ["聚", "jù"], ["。", ""], ["欲", "yù"], ["问", "wèn"], ["行", "xíng"], ["人", "rén"], ["去", "qù"], ["那", "nà"], ["边", "biān"], ["？", ""], ["眉", "méi"], ["眼", "yǎn"], ["盈", "yíng"], ["盈", "yíng"], ["处", "chù"], ["。", ""], ["才", "cái"], ["始", "shǐ"], ["送", "sòng"], ["春", "chūn"], ["归", "guī"], ["，", ""], ["又", "yòu"], ["送", "sòng"], ["君", "jūn"], ["归", "guī"], ["去", "qù"], ["。", ""], ["若", "ruò"], ["到", "dào"], ["江", "jiāng"], ["南", "nán"], ["赶", "gǎn"], ["上", "shàng"], ["春", "chūn"], ["，", ""], ["千", "qiān"], ["万", "wàn"], ["和", "hé"], ["春", "chūn"], ["住", "zhù"], ["。", ""]]], "sections": {"译文": "水是眼波横山是眉峰聚。行人去哪儿？眉眼盈盈处。才送春归又送君去。到江南赶上春千万和春住。", "注释": "- **眼波**：比喻水流如美人的目光。\n- **盈盈**：美好的样子。", "赏析": "以新颖比喻写送别。以送春写送人，千万和春住别出心裁。", "作者": "王观（生卒年不详），宋代词人。"}}, {"title": "回乡偶书", "poet": "贺知章", "dynasty": "唐", "type": "七言绝句", "theme": "思乡", "tags": [], "grade": "07-六年级", "grade_label": "六年级", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "学弈", "poet": "孟子", "dynasty": "战国", "type": "文言文", "theme": "学习", "tags": ["学习", "哲理", "文言文"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["弈秋，通国之善弈者也。使弈秋诲二人弈，其一人专心致志，惟弈秋之为听；一人虽听之，一心以为有鸿鹄将至，思援弓缴而射之。虽与之俱学，弗若之矣。"], "ruby": [[["弈", "yì"], ["秋", "qiū"], ["，", ""], ["通", "tōng"], ["国", "guó"], ["之", "zhī"], ["善", "shàn"], ["弈", "yì"], ["者", "zhě"], ["也", "yě"], ["。", ""], ["使", "shǐ"], ["弈", "yì"], ["秋", "qiū"], ["诲", "huì"], ["二", "èr"], ["人", "rén"], ["弈", "yì"], ["，", ""], ["其", "qí"], ["一", ""], ["人", "rén"], ["专", "zhuān"], ["心", "xīn"], ["致", "zhì"], ["志", "zhì"], ["，", ""], ["惟", "wéi"], ["弈", "yì"], ["秋", "qiū"], ["之", "zhī"], ["为", "wèi"], ["听", "tīng"], ["；", ""], ["一", ""], ["人", "rén"], ["虽", "suī"], ["听", "tīng"], ["之", "zhī"], ["，", ""], ["一", ""], ["心", "xīn"], ["以", "yǐ"], ["为", "wèi"], ["有", "yǒu"], ["鸿", "hóng"], ["鹄", "gǔ"], ["将", "jiāng"], ["至", "zhì"], ["，", ""], ["思", "sī"], ["援", "yuán"], ["弓", "gōng"], ["缴", "jiǎo"], ["而", "ér"], ["射", "shè"], ["之", "zhī"], ["。", ""], ["虽", "suī"], ["与", "yǔ"], ["之", "zhī"], ["俱", "jù"], ["学", "xué"], ["，", ""], ["弗", "fú"], ["若", "ruò"], ["之", "zhī"], ["矣", "yǐ"], ["。", ""]]], "sections": {"译文": "弈秋是全国最会下棋的人。他教两人下棋，一人专心致志只听弈秋的话；另一人虽然听着却想有天鹅飞来要用弓箭射它。后者的成绩不如前者。", "注释": "- **弈**：下棋。\n- **诲**：教导。\n- **鸿鹄**：天鹅。\n- **缴**：系着丝绳的箭。", "赏析": "以学弈为喻说明学习必须专心致志不能三心二意的道理。", "作者": "孟子（约前372年－前289年），名轲，战国时期儒家代表人物。"}}, {"title": "宿建德江", "poet": "孟浩然", "dynasty": "唐", "type": "五言绝句", "theme": "思乡", "tags": ["思乡", "写景", "羁旅"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["移舟泊烟渚，", "日暮客愁新。", "野旷天低树，", "江清月近人。"], "ruby": [[["移", "yí"], ["舟", "zhōu"], ["泊", "pō"], ["烟", "yān"], ["渚", "zhǔ"], ["，", ""]], [["日", "rì"], ["暮", "mù"], ["客", "kè"], ["愁", "chóu"], ["新", "xīn"], ["。", ""]], [["野", "yě"], ["旷", "kuàng"], ["天", "tiān"], ["低", "dī"], ["树", "shù"], ["，", ""]], [["江", "jiāng"], ["清", "qīng"], ["月", "yuè"], ["近", "jìn"], ["人", "rén"], ["。", ""]]], "sections": {"译文": "移舟停泊烟洲，日暮客愁新。原野旷天比树低，江清月近人。", "注释": "- **烟渚**：烟雾笼罩的水中小洲。", "赏析": "野旷天低树，江清月近人是千古名句。在空旷天地间只有月亮亲近旅人。", "作者": "孟浩然（689年－740年），唐代山水田园诗人。"}}, {"title": "寒食", "poet": "韩翃", "dynasty": "唐", "type": "七言绝句", "theme": "寒食", "tags": ["寒食", "节日", "春天"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["春城无处不飞花，", "寒食东风御柳斜。", "日暮汉宫传蜡烛，", "轻烟散入五侯家。"], "ruby": [[["春", "chūn"], ["城", "chéng"], ["无", "wú"], ["处", "chù"], ["不", "bù"], ["飞", "fēi"], ["花", "huā"], ["，", ""]], [["寒", "hán"], ["食", "shí"], ["东", "dōng"], ["风", "fēng"], ["御", "yù"], ["柳", "liǔ"], ["斜", "xié"], ["。", ""]], [["日", "rì"], ["暮", "mù"], ["汉", "hàn"], ["宫", "gōng"], ["传", "chuán"], ["蜡", "là"], ["烛", "zhú"], ["，", ""]], [["轻", "qīng"], ["烟", "yān"], ["散", "sàn"], ["入", "rù"], ["五", "wǔ"], ["侯", "hóu"], ["家", "jiā"], ["。", ""]]], "sections": {"译文": "春城无处不飞花，寒食东风御柳斜。日暮汉宫传蜡烛，轻烟散入五侯家。", "注释": "- **寒食**：清明前一两天，禁火吃冷食。\n- **五侯**：泛指权贵。", "赏析": "春城无处不飞花写出春日繁盛。后两句暗含对权贵特权的讽喻。", "作者": "韩翃（生卒年不详），唐代诗人，大历十才子之一。"}}, {"title": "早春呈水部张十八员外", "poet": "韩愈", "dynasty": "唐", "type": "七言绝句", "theme": "春天", "tags": ["春天", "写景", "早春"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["天街小雨润如酥，", "草色遥看近却无。", "最是一年春好处，", "绝胜烟柳满皇都。"], "ruby": [[["天", "tiān"], ["街", "jiē"], ["小", "xiǎo"], ["雨", "yǔ"], ["润", "rùn"], ["如", "rú"], ["酥", "sū"], ["，", ""]], [["草", "cǎo"], ["色", "sè"], ["遥", "yáo"], ["看", "kàn"], ["近", "jìn"], ["却", "què"], ["无", "wú"], ["。", ""]], [["最", "zuì"], ["是", "shì"], ["一", ""], ["年", "nián"], ["春", "chūn"], ["好", "hǎo"], ["处", "chù"], ["，", ""]], [["绝", "jué"], ["胜", "shèng"], ["烟", "yān"], ["柳", "liǔ"], ["满", "mǎn"], ["皇", "huáng"], ["都", "dōu"], ["。", ""]]], "sections": {"译文": "天街小雨润如酥，草色遥看近却无。最是一年春好处，绝胜烟柳满皇都。", "注释": "- **酥**：酥油。\n- **绝胜**：远远超过。", "赏析": "草色遥看近却无以极简笔墨写出早春草芽初萌的微妙状态。", "作者": "韩愈（768年－824年），字退之，唐代文学家，唐宋八大家之首。"}}, {"title": "春夜喜雨", "poet": "", "dynasty": "", "type": "", "theme": "", "tags": [], "grade": "07-六年级", "grade_label": "六年级", "lines": ["好雨知时节，", "当春乃发生。", "随风潜入夜，", "润物细无声。", "野径云俱黑，", "江船火独明。", "晓看红湿处，", "花重锦官城。"], "ruby": [[["好", "hǎo"], ["雨", "yǔ"], ["知", "zhī"], ["时", "shí"], ["节", "jié"], ["，", ""]], [["当", "dāng"], ["春", "chūn"], ["乃", "nǎi"], ["发", "fā"], ["生", "shēng"], ["。", ""]], [["随", "suí"], ["风", "fēng"], ["潜", "qián"], ["入", "rù"], ["夜", "yè"], ["，", ""]], [["润", "rùn"], ["物", "wù"], ["细", "xì"], ["无", "wú"], ["声", "shēng"], ["。", ""]], [["野", "yě"], ["径", "jìng"], ["云", "yún"], ["俱", "jù"], ["黑", "hēi"], ["，", ""]], [["江", "jiāng"], ["船", "chuán"], ["火", "huǒ"], ["独", "dú"], ["明", "míng"], ["。", ""]], [["晓", "xiǎo"], ["看", "kàn"], ["红", "hóng"], ["湿", "shī"], ["处", "chù"], ["，", ""]], [["花", "huā"], ["重", "zhòng"], ["锦", "jǐn"], ["官", "guān"], ["城", "chéng"], ["。", ""]]], "sections": {"译文": "好雨似乎知道时节，正当春天万物生长时就降临了。它伴随微风在夜里悄悄落下，细细密密地滋润万物没有一点声响。野外的小路和天上的乌云都黑沉沉的，只有江上的渔船灯火独自明亮。等到早晨看那被雨水打湿的红花，沉甸甸地开满了整个锦官城。", "注释": "- **知**：知道，懂得。\n- **乃**：就，于是。\n- **发生**：使万物萌发生长。\n- **潜**：悄悄地。\n- **润物**：滋润万物。\n- **野径**：田野间的小路。\n- **红湿**：被雨水打湿的红花。\n- **花重**：花因沾雨水而显得沉甸甸。\n- **锦官城**：成都的别称。", "赏析": "这是杜甫寓居成都时所作。开篇以\"好雨\"领起，拟人写出雨知时节、应时而降之喜。\"随风潜入夜，润物细无声\"传神写出春雨细密柔和的特点。颈联写雨夜之景，黑与明相对。尾联想象雨后花重锦官城，喜悦之情溢于言表。全诗细致入微，被誉为咏雨的千古名篇。", "作者": "杜甫（712年－770年），字子美，自号少陵野老，唐代伟大的现实主义诗人，\"诗圣\"。其诗被称为\"诗史\"。"}}, {"title": "春日", "poet": "朱熹", "dynasty": "宋", "type": "七言绝句", "theme": "春天", "tags": ["春天", "哲理", "写景"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["胜日寻芳泗水滨，", "无边光景一时新。", "等闲识得东风面，", "万紫千红总是春。"], "ruby": [[["胜", "shèng"], ["日", "rì"], ["寻", "xún"], ["芳", "fāng"], ["泗", "sì"], ["水", "shuǐ"], ["滨", "bīn"], ["，", ""]], [["无", "wú"], ["边", "biān"], ["光", "guāng"], ["景", "jǐng"], ["一", ""], ["时", "shí"], ["新", "xīn"], ["。", ""]], [["等", "děng"], ["闲", "xián"], ["识", "shí"], ["得", "dé"], ["东", "dōng"], ["风", "fēng"], ["面", "miàn"], ["，", ""]], [["万", "wàn"], ["紫", "zǐ"], ["千", "qiān"], ["红", "hóng"], ["总", "zǒng"], ["是", "shì"], ["春", "chūn"], ["。", ""]]], "sections": {"译文": "胜日寻芳泗水边，无边光景焕然一新。随处看到东风面，万紫千红都是春。", "注释": "- **胜日**：天气晴好的日子。\n- **泗水**：水名，在今山东。", "赏析": "万紫千红总是春揭示了万物皆含春意的哲理。情景交融理趣盎然。", "作者": "朱熹（1130年－1200年），字元晦，号晦庵，南宋理学家。"}}, {"title": "江上渔者", "poet": "范仲淹", "dynasty": "宋", "type": "五言绝句", "theme": "民生", "tags": ["民生", "渔人", "同情"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["江上往来人，", "但爱鲈鱼美。", "君看一叶舟，", "出没风波里。"], "ruby": [[["江", "jiāng"], ["上", "shàng"], ["往", "wǎng"], ["来", "lái"], ["人", "rén"], ["，", ""]], [["但", "dàn"], ["爱", "ài"], ["鲈", "lú"], ["鱼", "yú"], ["美", "měi"], ["。", ""]], [["君", "jūn"], ["看", "kàn"], ["一", ""], ["叶", "yè"], ["舟", "zhōu"], ["，", ""]], [["出", "chū"], ["没", "méi"], ["风", "fēng"], ["波", "bō"], ["里", "lǐ"], ["。", ""]]], "sections": {"译文": "江边往来人只爱鲈鱼鲜美。你看那一叶小舟在风浪中时隐时现。", "注释": "- **但**：只。\n- **一叶舟**：像树叶一样的小船。", "赏析": "以简短对比引人深思。表达了对劳动者的深切同情。", "作者": "范仲淹（989年－1052年），字希文，北宋政治家。"}}, {"title": "江南春", "poet": "杜牧", "dynasty": "唐", "type": "七言绝句", "theme": "江南", "tags": ["江南", "春天", "写景"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["千里莺啼绿映红，", "水村山郭酒旗风。", "南朝四百八十寺，", "多少楼台烟雨中。"], "ruby": [[["千", "qiān"], ["里", "lǐ"], ["莺", "yīng"], ["啼", "tí"], ["绿", "lǜ"], ["映", "yìng"], ["红", "hóng"], ["，", ""]], [["水", "shuǐ"], ["村", "cūn"], ["山", "shān"], ["郭", "guō"], ["酒", "jiǔ"], ["旗", "qí"], ["风", "fēng"], ["。", ""]], [["南", "nán"], ["朝", "cháo"], ["四", "sì"], ["百", "bǎi"], ["八", "bā"], ["十", "shí"], ["寺", "sì"], ["，", ""]], [["多", "duō"], ["少", "shǎo"], ["楼", "lóu"], ["台", "tái"], ["烟", "yān"], ["雨", "yǔ"], ["中", "zhōng"], ["。", ""]]], "sections": {"译文": "千里江南莺啼绿映红，水村山郭酒旗迎风。南朝四百八十寺，多少楼台在烟雨中。", "注释": "- **山郭**：靠山的城郭。\n- **南朝**：宋齐梁陈四朝。", "赏析": "以高度概括的笔触描绘江南春日全景。莺啼绿红与烟雨楼台形成对比。", "作者": "杜牧（803年－852年），字牧之，唐代诗人。"}}, {"title": "泊船瓜洲", "poet": "", "dynasty": "", "type": "", "theme": "", "tags": [], "grade": "07-六年级", "grade_label": "六年级", "lines": ["京口瓜洲一水间，", "钟山只隔数重山。", "春风又绿江南岸，", "明月何时照我还？"], "ruby": [[["京", "jīng"], ["口", "kǒu"], ["瓜", "guā"], ["洲", "zhōu"], ["一", ""], ["水", "shuǐ"], ["间", "jiān"], ["，", ""]], [["钟", "zhōng"], ["山", "shān"], ["只", "zhǐ"], ["隔", "gé"], ["数", "shù"], ["重", "chóng"], ["山", "shān"], ["。", ""]], [["春", "chūn"], ["风", "fēng"], ["又", "yòu"], ["绿", "lǜ"], ["江", "jiāng"], ["南", "nán"], ["岸", "àn"], ["，", ""]], [["明", "míng"], ["月", "yuè"], ["何", "hé"], ["时", "shí"], ["照", "zhào"], ["我", "wǒ"], ["还", "huán"], ["？", ""]]], "sections": {"译文": "京口和瓜洲只隔着一条长江，钟山也只隔着几重山峦。春风又吹绿了长江南岸的草木，天上的明月什么时候照着我回到故乡？", "注释": "- **泊**：停船靠岸。\n- **瓜洲**：在今江苏扬州南，长江北岸。\n- **京口**：今江苏镇江，长江南岸。\n- **一水**：指长江。\n- **钟山**：今南京紫金山，作者故乡。\n- **绿**：吹绿（使动用法）。", "赏析": "前两句写地理位置之近，京口、瓜洲、钟山仅一江一山之隔，暗含归乡之易；\"春风又绿江南岸\"一句\"绿\"字炼字精妙，写出春风拂绿江南的动态与生机；\"明月何时照我还\"以问作结，思乡之情随明月远扬。全诗语言清丽，思乡之意含蓄深沉。", "作者": "王安石（1021年－1086年），字介甫，号半山，北宋政治家、文学家。\"唐宋八大家\"之一。"}}, {"title": "浣溪沙·游蕲水清泉寺", "poet": "苏轼", "dynasty": "宋", "type": "词", "theme": "旷达", "tags": ["旷达", "哲理", "词"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["山下兰芽短浸溪，松间沙路净无泥，萧萧暮雨子规啼。谁道人生无再少？门前流水尚能西！休将白发唱黄鸡。"], "ruby": [[["山", "shān"], ["下", "xià"], ["兰", "lán"], ["芽", "yá"], ["短", "duǎn"], ["浸", "jìn"], ["溪", "xī"], ["，", ""], ["松", "sōng"], ["间", "jiān"], ["沙", "shā"], ["路", "lù"], ["净", "jìng"], ["无", "wú"], ["泥", "ní"], ["，", ""], ["萧", "xiāo"], ["萧", "xiāo"], ["暮", "mù"], ["雨", "yǔ"], ["子", "zi"], ["规", "guī"], ["啼", "tí"], ["。", ""], ["谁", "shuí"], ["道", "dào"], ["人", "rén"], ["生", "shēng"], ["无", "wú"], ["再", "zài"], ["少", "shǎo"], ["？", ""], ["门", "mén"], ["前", "qián"], ["流", "liú"], ["水", "shuǐ"], ["尚", "shàng"], ["能", "néng"], ["西", "xī"], ["！", ""], ["休", "xiū"], ["将", "jiāng"], ["白", "bái"], ["发", "fā"], ["唱", "chàng"], ["黄", "huáng"], ["鸡", "jī"], ["。", ""]]], "sections": {"译文": "山下兰芽短浸溪，松间沙路净无泥，萧萧暮雨子规啼。谁道人生无再少？门前流水尚能西！休将白发唱黄鸡。", "注释": "- **子规**：杜鹃鸟。\n- **尚能西**：还能向西流。", "赏析": "以谁道人生无再少的反问振起，充满积极向上的精神。", "作者": "苏轼（1037年－1101年），字子瞻，号东坡居士，北宋文学家。"}}, {"title": "清平乐·春归何处", "poet": "黄庭坚", "dynasty": "宋", "type": "词", "theme": "惜春", "tags": ["惜春", "词", "咏怀"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["春归何处？寂寞无行路。若有人知春去处，唤取归来同住。春无踪迹谁知？除非问取黄鹂。百啭无人能解，因风飞过蔷薇。"], "ruby": [[["春", "chūn"], ["归", "guī"], ["何", "hé"], ["处", "chù"], ["？", ""], ["寂", "jì"], ["寞", "mò"], ["无", "wú"], ["行", "xíng"], ["路", "lù"], ["。", ""], ["若", "ruò"], ["有", "yǒu"], ["人", "rén"], ["知", "zhī"], ["春", "chūn"], ["去", "qù"], ["处", "chù"], ["，", ""], ["唤", "huàn"], ["取", "qǔ"], ["归", "guī"], ["来", "lái"], ["同", "tóng"], ["住", "zhù"], ["。", ""], ["春", "chūn"], ["无", "wú"], ["踪", "zōng"], ["迹", "jì"], ["谁", "shuí"], ["知", "zhī"], ["？", ""], ["除", "chú"], ["非", "fēi"], ["问", "wèn"], ["取", "qǔ"], ["黄", "huáng"], ["鹂", "lí"], ["。", ""], ["百", "bǎi"], ["啭", "zhuàn"], ["无", "wú"], ["人", "rén"], ["能", "néng"], ["解", "jiě"], ["，", ""], ["因", "yīn"], ["风", "fēng"], ["飞", "fēi"], ["过", "guò"], ["蔷", "qiáng"], ["薇", "wēi"], ["。", ""]]], "sections": {"译文": "春归何处？寂寞无行路。若有人知春去处唤取归来同住。春无踪迹谁知？除非问取黄鹂。百啭无人能解因风飞过蔷薇。", "注释": "- **无行路**：没有留下踪迹。\n- **百啭**：形容鸟鸣婉转动听。", "赏析": "以天真的追问写惜春之情。全词含蓄委婉饶有韵味。", "作者": "黄庭坚（1045年－1105年），字鲁直，号山谷道人，北宋诗人。"}}, {"title": "游园不值", "poet": "叶绍翁", "dynasty": "宋", "type": "七言绝句", "theme": "春天", "tags": ["春天", "哲理", "写景"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["应怜屐齿印苍苔，", "小扣柴扉久不开。", "春色满园关不住，", "一枝红杏出墙来。"], "ruby": [[["应", "yīng"], ["怜", "lián"], ["屐", "jī"], ["齿", "chǐ"], ["印", "yìn"], ["苍", "cāng"], ["苔", "tái"], ["，", ""]], [["小", "xiǎo"], ["扣", "kòu"], ["柴", "chái"], ["扉", "fēi"], ["久", "jiǔ"], ["不", "bù"], ["开", "kāi"], ["。", ""]], [["春", "chūn"], ["色", "sè"], ["满", "mǎn"], ["园", "yuán"], ["关", "guān"], ["不", "bù"], ["住", "zhù"], ["，", ""]], [["一", ""], ["枝", "zhī"], ["红", "hóng"], ["杏", "xìng"], ["出", "chū"], ["墙", "qiáng"], ["来", "lái"], ["。", ""]]], "sections": {"译文": "大概主人爱惜苍苔，我敲了许久柴门不开。满园春色关不住，一枝红杏出墙来。", "注释": "- **不值**：没遇到主人。\n- **屐齿**：木屐的齿印。\n- **柴扉**：柴门。", "赏析": "春色满园关不住，一枝红杏出墙来是极富哲理的名句。美好的事物终究关不住。", "作者": "叶绍翁（生卒年不详），南宋诗人。"}}, {"title": "石灰吟", "poet": "于谦", "dynasty": "明", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "气节", "励志"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["千锤万凿出深山，", "烈火焚烧若等闲。", "粉骨碎身浑不怕，", "要留清白在人间。"], "ruby": [[["千", "qiān"], ["锤", "chuí"], ["万", "wàn"], ["凿", "záo"], ["出", "chū"], ["深", "shēn"], ["山", "shān"], ["，", ""]], [["烈", "liè"], ["火", "huǒ"], ["焚", "fén"], ["烧", "shāo"], ["若", "ruò"], ["等", "děng"], ["闲", "xián"], ["。", ""]], [["粉", "fěn"], ["骨", "gǔ"], ["碎", "suì"], ["身", "shēn"], ["浑", "hún"], ["不", "bù"], ["怕", "pà"], ["，", ""]], [["要", "yào"], ["留", "liú"], ["清", "qīng"], ["白", "bái"], ["在", "zài"], ["人", "rén"], ["间", "jiān"], ["。", ""]]], "sections": {"译文": "千锤万凿出深山，烈火焚烧若等闲。粉身碎骨浑不怕，要留清白在人间。", "注释": "- **若等闲**：好像很平常。\n- **浑**：全。\n- **清白**：双关，既指石灰颜色也指人的品格。", "赏析": "以石灰自喻托物言志。要留清白在人间表达了坚守清白不畏牺牲的崇高气节。", "作者": "于谦（1398年－1457年），明朝政治家、军事家、诗人。"}}, {"title": "竹石", "poet": "郑燮", "dynasty": "清", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "竹子", "气节"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["咬定青山不放松，", "立根原在破岩中。", "千磨万击还坚劲，", "任尔东西南北风。"], "ruby": [[["咬", "yǎo"], ["定", "dìng"], ["青", "qīng"], ["山", "shān"], ["不", "bù"], ["放", "fàng"], ["松", "sōng"], ["，", ""]], [["立", "lì"], ["根", "gēn"], ["原", "yuán"], ["在", "zài"], ["破", "pò"], ["岩", "yán"], ["中", "zhōng"], ["。", ""]], [["千", "qiān"], ["磨", "mó"], ["万", "wàn"], ["击", "jī"], ["还", "hái"], ["坚", "jiān"], ["劲", "jìn"], ["，", ""]], [["任", "rèn"], ["尔", "ěr"], ["东", "dōng"], ["西", "xī"], ["南", "nán"], ["北", "běi"], ["风", "fēng"], ["。", ""]]], "sections": {"译文": "竹子咬定青山不放松，根基扎在破岩中。千磨万击还坚劲，任尔东西南北风。", "注释": "- **咬定**：竹根牢牢扎在山石中。\n- **尔**：你。", "赏析": "咏竹言志。千磨万击还坚劲，任尔东西南北风是画家自我品格的写照。", "作者": "郑燮（1693年－1766年），字克柔，号板桥，清代画家，扬州八怪之一。"}}, {"title": "西江月·夜行黄沙道中", "poet": "辛弃疾", "dynasty": "宋", "type": "词", "theme": "田园", "tags": ["田园", "词", "夏天"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["明月别枝惊鹊，清风半夜鸣蝉。稻花香里说丰年，听取蛙声一片。七八个星天外，两三点雨山前。旧时茅店社林边，路转溪桥忽见。"], "ruby": [[["明", "míng"], ["月", "yuè"], ["别", "bié"], ["枝", "zhī"], ["惊", "jīng"], ["鹊", "què"], ["，", ""], ["清", "qīng"], ["风", "fēng"], ["半", "bàn"], ["夜", "yè"], ["鸣", "míng"], ["蝉", "chán"], ["。", ""], ["稻", "dào"], ["花", "huā"], ["香", "xiāng"], ["里", "lǐ"], ["说", "shuō"], ["丰", "fēng"], ["年", "nián"], ["，", ""], ["听", "tīng"], ["取", "qǔ"], ["蛙", "wā"], ["声", "shēng"], ["一", ""], ["片", "piàn"], ["。", ""], ["七", "qī"], ["八", "bā"], ["个", "gè"], ["星", "xīng"], ["天", "tiān"], ["外", "wài"], ["，", ""], ["两", "liǎng"], ["三", "sān"], ["点", "diǎn"], ["雨", "yǔ"], ["山", "shān"], ["前", "qián"], ["。", ""], ["旧", "jiù"], ["时", "shí"], ["茅", "máo"], ["店", "diàn"], ["社", "shè"], ["林", "lín"], ["边", "biān"], ["，", ""], ["路", "lù"], ["转", "zhuǎn"], ["溪", "xī"], ["桥", "qiáo"], ["忽", "hū"], ["见", "xiàn"], ["。", ""]]], "sections": {"译文": "明月惊鹊清风鸣蝉。稻花香里说丰年听取蛙声一片。七八个星天外两三点雨山前。旧时茅店在社林边转过溪桥忽然出现。", "注释": "- **别枝**：斜出的树枝。\n- **见**：同现，出现。", "赏析": "此词写夜行乡间所见所闻。稻花香里说丰年将自然之景与农人之乐相融合。", "作者": "辛弃疾（1140年－1207年），字幼安，号稼轩，南宋豪放派词人。"}}, {"title": "过故人庄", "poet": "孟浩然", "dynasty": "唐", "type": "五言律诗", "theme": "田园", "tags": ["田园", "友情", "农村"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["故人具鸡黍，邀我至田家。绿树村边合，青山郭外斜。开轩面场圃，把酒话桑麻。待到重阳日，还来就菊花。"], "ruby": [[["故", "gù"], ["人", "rén"], ["具", "jù"], ["鸡", "jī"], ["黍", "shǔ"], ["，", ""], ["邀", "yāo"], ["我", "wǒ"], ["至", "zhì"], ["田", "tián"], ["家", "jiā"], ["。", ""], ["绿", "lǜ"], ["树", "shù"], ["村", "cūn"], ["边", "biān"], ["合", "hé"], ["，", ""], ["青", "qīng"], ["山", "shān"], ["郭", "guō"], ["外", "wài"], ["斜", "xié"], ["。", ""], ["开", "kāi"], ["轩", "xuān"], ["面", "miàn"], ["场", "chǎng"], ["圃", "pǔ"], ["，", ""], ["把", "bǎ"], ["酒", "jiǔ"], ["话", "huà"], ["桑", "sāng"], ["麻", "má"], ["。", ""], ["待", "dài"], ["到", "dào"], ["重", "zhòng"], ["阳", "yáng"], ["日", "rì"], ["，", ""], ["还", "huán"], ["来", "lái"], ["就", "jiù"], ["菊", "jú"], ["花", "huā"], ["。", ""]]], "sections": {"译文": "老友备鸡黍邀我到田家。绿树绕村青山斜。开窗对场圃举杯话桑麻。待到重阳日还来赏菊花。", "注释": "- **具**：准备。\n- **场圃**：打谷场和菜园。", "赏析": "以淡雅笔调写田园访友的愉悦。绿树村边合青山郭外斜写景开阔优美。", "作者": "孟浩然（689年－740年），唐代山水田园诗人。"}}, {"title": "迢迢牵牛星", "poet": "古诗十九首", "dynasty": "汉", "type": "五言古诗", "theme": "七夕", "tags": ["七夕", "爱情", "古诗"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["迢迢牵牛星，皎皎河汉女。纤纤擢素手，札札弄机杼。终日不成章，泣涕零如雨。河汉清且浅，相去复几许？盈盈一水间，脉脉不得语。"], "ruby": [[["迢", "tiáo"], ["迢", "tiáo"], ["牵", "qiān"], ["牛", "niú"], ["星", "xīng"], ["，", ""], ["皎", "jiǎo"], ["皎", "jiǎo"], ["河", "hé"], ["汉", "hàn"], ["女", "nǚ"], ["。", ""], ["纤", "xiān"], ["纤", "xiān"], ["擢", "zhuó"], ["素", "sù"], ["手", "shǒu"], ["，", ""], ["札", "zhá"], ["札", "zhá"], ["弄", "nòng"], ["机", "jī"], ["杼", "zhù"], ["。", ""], ["终", "zhōng"], ["日", "rì"], ["不", "bù"], ["成", "chéng"], ["章", "zhāng"], ["，", ""], ["泣", "qì"], ["涕", "tì"], ["零", "líng"], ["如", "rú"], ["雨", "yǔ"], ["。", ""], ["河", "hé"], ["汉", "hàn"], ["清", "qīng"], ["且", "qiě"], ["浅", "qiǎn"], ["，", ""], ["相", "xiāng"], ["去", "qù"], ["复", "fù"], ["几", "jǐ"], ["许", "xǔ"], ["？", ""], ["盈", "yíng"], ["盈", "yíng"], ["一", ""], ["水", "shuǐ"], ["间", "jiān"], ["，", ""], ["脉", "mài"], ["脉", "mài"], ["不", "bù"], ["得", "dé"], ["语", "yǔ"], ["。", ""]]], "sections": {"译文": "迢迢牵牛星皎皎织女星。纤纤擢手札札弄机杼。终日不成章泣涕零如雨。河汉清且浅相隔复几许？盈盈一水间脉脉不得语。", "注释": "- **擢**：伸出。\n- **零**：落下。\n- **脉脉**：含情相视。", "赏析": "借牛郎织女写人间相思。叠词运用最为突出，音韵和谐情感缠绵。", "作者": "《古诗十九首》最早收录于《文选》。"}}, {"title": "采薇（节选）", "poet": "诗经", "dynasty": "先秦", "type": "四言古诗", "theme": "边塞", "tags": ["边塞", "思乡", "诗经"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["昔我往矣，杨柳依依。今我来思，雨雪霏霏。行道迟迟，载渴载饥。我心伤悲，莫知我哀！"], "ruby": [[["昔", "xī"], ["我", "wǒ"], ["往", "wǎng"], ["矣", "yǐ"], ["，", ""], ["杨", "yáng"], ["柳", "liǔ"], ["依", "yī"], ["依", "yī"], ["。", ""], ["今", "jīn"], ["我", "wǒ"], ["来", "lái"], ["思", "sī"], ["，", ""], ["雨", "yǔ"], ["雪", "xuě"], ["霏", "fēi"], ["霏", "fēi"], ["。", ""], ["行", "xíng"], ["道", "dào"], ["迟", "chí"], ["迟", "chí"], ["，", ""], ["载", "zài"], ["渴", "kě"], ["载", "zài"], ["饥", "jī"], ["。", ""], ["我", "wǒ"], ["心", "xīn"], ["伤", "shāng"], ["悲", "bēi"], ["，", ""], ["莫", "mò"], ["知", "zhī"], ["我", "wǒ"], ["哀", "āi"], ["！", ""]]], "sections": {"译文": "当初我出征杨柳依依。如今我归来雨雪霏霏。行道迟迟又渴又饥。我心伤悲莫知我哀！", "注释": "- **依依**：柳枝轻柔飘动的样子。\n- **雨雪**：下雪。", "赏析": "以乐景写哀以哀景写悲。以出征杨柳和归来雨雪对比，情景交融感人至深。", "作者": "《诗经》是中国最早的诗歌总集。"}}, {"title": "长歌行", "poet": "汉乐府", "dynasty": "汉", "type": "乐府诗", "theme": "惜时", "tags": ["惜时", "哲理", "乐府诗"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["青青园中葵，朝露待日晞。阳春布德泽，万物生光辉。常恐秋节至，焜黄华叶衰。百川东到海，何时复西归？少壮不努力，老大徒伤悲。"], "ruby": [[["青", "qīng"], ["青", "qīng"], ["园", "yuán"], ["中", "zhōng"], ["葵", "kuí"], ["，", ""], ["朝", "cháo"], ["露", "lù"], ["待", "dài"], ["日", "rì"], ["晞", "xī"], ["。", ""], ["阳", "yáng"], ["春", "chūn"], ["布", "bù"], ["德", "dé"], ["泽", "zé"], ["，", ""], ["万", "wàn"], ["物", "wù"], ["生", "shēng"], ["光", "guāng"], ["辉", "huī"], ["。", ""], ["常", "cháng"], ["恐", "kǒng"], ["秋", "qiū"], ["节", "jié"], ["至", "zhì"], ["，", ""], ["焜", "kūn"], ["黄", "huáng"], ["华", "huá"], ["叶", "yè"], ["衰", "shuāi"], ["。", ""], ["百", "bǎi"], ["川", "chuān"], ["东", "dōng"], ["到", "dào"], ["海", "hǎi"], ["，", ""], ["何", "hé"], ["时", "shí"], ["复", "fù"], ["西", "xī"], ["归", "guī"], ["？", ""], ["少", "shǎo"], ["壮", "zhuàng"], ["不", "bù"], ["努", "nǔ"], ["力", "lì"], ["，", ""], ["老", "lǎo"], ["大", "dà"], ["徒", "tú"], ["伤", "shāng"], ["悲", "bēi"], ["。", ""]]], "sections": {"译文": "园中葵青青朝露待日晞。阳春布泽万物生辉。常恐秋天到花叶枯黄。百川东到海何时复西归？少壮不努力老大徒伤悲。", "注释": "- **晞**：晒干。\n- **焜黄**：枯黄。\n- **徒**：白白地。", "赏析": "劝勉珍惜光阴的乐府诗。少壮不努力，老大徒伤悲是千古箴言。", "作者": "本篇选自《乐府诗集》。"}}, {"title": "闻官军收河南河北", "poet": "杜甫", "dynasty": "唐", "type": "七言律诗", "theme": "爱国", "tags": ["爱国", "喜悦", "杜甫"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["剑外忽传收蓟北，初闻涕泪满衣裳。却看妻子愁何在，漫卷诗书喜欲狂。白日放歌须纵酒，青春作伴好还乡。即从巴峡穿巫峡，便下襄阳向洛阳。"], "ruby": [[["剑", "jiàn"], ["外", "wài"], ["忽", "hū"], ["传", "chuán"], ["收", "shōu"], ["蓟", "jì"], ["北", "běi"], ["，", ""], ["初", "chū"], ["闻", "wén"], ["涕", "tì"], ["泪", "lèi"], ["满", "mǎn"], ["衣", "yī"], ["裳", "shang"], ["。", ""], ["却", "què"], ["看", "kàn"], ["妻", "qī"], ["子", "zi"], ["愁", "chóu"], ["何", "hé"], ["在", "zài"], ["，", ""], ["漫", "màn"], ["卷", "juǎn"], ["诗", "shī"], ["书", "shū"], ["喜", "xǐ"], ["欲", "yù"], ["狂", "kuáng"], ["。", ""], ["白", "bái"], ["日", "rì"], ["放", "fàng"], ["歌", "gē"], ["须", "xū"], ["纵", "zòng"], ["酒", "jiǔ"], ["，", ""], ["青", "qīng"], ["春", "chūn"], ["作", "zuò"], ["伴", "bàn"], ["好", "hǎo"], ["还", "hái"], ["乡", "xiāng"], ["。", ""], ["即", "jí"], ["从", "cóng"], ["巴", "bā"], ["峡", "xiá"], ["穿", "chuān"], ["巫", "wū"], ["峡", "xiá"], ["，", ""], ["便", "biàn"], ["下", "xià"], ["襄", "xiāng"], ["阳", "yáng"], ["向", "xiàng"], ["洛", "luò"], ["阳", "yáng"], ["。", ""]]], "sections": {"译文": "剑外忽传收蓟北，初闻涕泪满衣裳。回头看妻子愁已散，漫卷诗书喜欲狂。白日放歌纵酒，青春作伴好还乡。即从巴峡穿巫峡，便下襄阳向洛阳。", "注释": "- **剑外**：剑门关以南。\n- **蓟北**：安史叛军根据地。", "赏析": "此为杜甫生平第一快诗。闻讯后欣喜若狂的心情和急切返乡之情一气呵成。", "作者": "杜甫（712年－770年），字子美，号少陵野老，唐代伟大的现实主义诗人。"}}, {"title": "马诗", "poet": "李贺", "dynasty": "唐", "type": "五言绝句", "theme": "咏物", "tags": ["咏物", "励志", "怀才不遇"], "grade": "07-六年级", "grade_label": "六年级", "lines": ["大漠沙如雪，", "燕山月似钩。", "何当金络脑，", "快走踏清秋。"], "ruby": [[["大", "dà"], ["漠", "mò"], ["沙", "shā"], ["如", "rú"], ["雪", "xuě"], ["，", ""]], [["燕", "yàn"], ["山", "shān"], ["月", "yuè"], ["似", "shì"], ["钩", "gōu"], ["。", ""]], [["何", "hé"], ["当", "dāng"], ["金", "jīn"], ["络", "luò"], ["脑", "nǎo"], ["，", ""]], [["快", "kuài"], ["走", "zǒu"], ["踏", "tà"], ["清", "qīng"], ["秋", "qiū"], ["。", ""]]], "sections": {"译文": "大漠沙如雪燕山月似钩。什么时候才能戴上金笼头在清秋中奔驰？", "注释": "- **何当**：什么时候才能。\n- **金络脑**：金饰的马笼头。", "赏析": "借马喻人表达渴望被重用一展才华的志向。", "作者": "李贺（约790年－约817年），字长吉，唐代诗人，被誉为诗鬼。"}}]}