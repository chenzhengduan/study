{"grade": "05-四年级", "label": "四年级", "count": 21, "poems": [{"title": "凉州词", "poet": "王翰", "dynasty": "唐", "type": "七言绝句", "theme": "边塞", "tags": ["边塞", "战争", "豪迈"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["葡萄美酒夜光杯，", "欲饮琵琶马上催。", "醉卧沙场君莫笑，", "古来征战几人回？"], "ruby": [[["葡", "pú"], ["萄", "táo"], ["美", "měi"], ["酒", "jiǔ"], ["夜", "yè"], ["光", "guāng"], ["杯", "bēi"], ["，", ""]], [["欲", "yù"], ["饮", "yǐn"], ["琵", "pí"], ["琶", "pá"], ["马", "mǎ"], ["上", "shàng"], ["催", "cuī"], ["。", ""]], [["醉", "zuì"], ["卧", "wò"], ["沙", "shā"], ["场", "chǎng"], ["君", "jūn"], ["莫", "mò"], ["笑", "xiào"], ["，", ""]], [["古", "gǔ"], ["来", "lái"], ["征", "zhēng"], ["战", "zhàn"], ["几", "jǐ"], ["人", "rén"], ["回", "huí"], ["？", ""]]], "sections": {"译文": "葡萄美酒斟满夜光杯，正要畅饮琵琶催人出发。醉倒沙场不要笑话，自古征人几个能活着回来？", "注释": "- **夜光杯**：精美的酒杯。\n- **沙场**：战场。", "赏析": "此诗以豪放笔调写边塞将士的悲壮。醉卧沙场的洒脱写出视死如归的豪情，悲凉而慷慨。", "作者": "王翰（生卒年不详），字子羽，唐代边塞诗人。"}}, {"title": "出塞", "poet": "王昌龄", "dynasty": "唐", "type": "七言绝句", "theme": "边塞", "tags": ["边塞", "思乡", "月亮"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["秦时明月汉时关，", "万里长征人未还。", "但使龙城飞将在，", "不教胡马度阴山。"], "ruby": [[["秦", "qín"], ["时", "shí"], ["明", "míng"], ["月", "yuè"], ["汉", "hàn"], ["时", "shí"], ["关", "guān"], ["，", ""]], [["万", "wàn"], ["里", "lǐ"], ["长", "cháng"], ["征", "zhēng"], ["人", "rén"], ["未", "wèi"], ["还", "huán"], ["。", ""]], [["但", "dàn"], ["使", "shǐ"], ["龙", "lóng"], ["城", "chéng"], ["飞", "fēi"], ["将", "jiàng"], ["在", "zài"], ["，", ""]], [["不", "bù"], ["教", "jiào"], ["胡", "hú"], ["马", "mǎ"], ["度", "dù"], ["阴", "yīn"], ["山", "shān"], ["。", ""]]], "sections": {"译文": "秦时的明月照着汉时的边关，万里长征的将士至今未还。只要龙城的飞将李广还在，绝不教胡人的战马跨过阴山。", "注释": "- **关**：边关。\n- **长征**：长途出征。\n- **但使**：只要。\n- **龙城飞将**：汉将李广，匈奴称其为\"飞将军\"。\n- **教**：让，使。\n- **胡马**：胡人的战马。\n- **阴山**：横亘于北方的山脉。", "赏析": "\"秦时明月汉时关\"一句时空交错，将眼前的明月边关与秦汉的战争历史打通，气象浑厚苍凉。次句写万里长征未还之悲，后两句盼望有良将在、边患息。全诗被誉为唐人七绝压卷之作，雄浑而含蕴家国之思。", "作者": "王昌龄（约698年－约757年），字少伯，唐代诗人，擅长七绝，被誉为\"七绝圣手\"。"}}, {"title": "别董大", "poet": "高适", "dynasty": "唐", "type": "七言绝句", "theme": "送别", "tags": ["送别", "友情", "豪迈"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["千里黄云白日曛，", "北风吹雁雪纷纷。", "莫愁前路无知己，", "天下谁人不识君？"], "ruby": [[["千", "qiān"], ["里", "lǐ"], ["黄", "huáng"], ["云", "yún"], ["白", "bái"], ["日", "rì"], ["曛", "xūn"], ["，", ""]], [["北", "běi"], ["风", "fēng"], ["吹", "chuī"], ["雁", "yàn"], ["雪", "xuě"], ["纷", "fēn"], ["纷", "fēn"], ["。", ""]], [["莫", "mò"], ["愁", "chóu"], ["前", "qián"], ["路", "lù"], ["无", "wú"], ["知", "zhī"], ["己", "jǐ"], ["，", ""]], [["天", "tiān"], ["下", "xià"], ["谁", "shuí"], ["人", "rén"], ["不", "bù"], ["识", "shí"], ["君", "jūn"], ["？", ""]]], "sections": {"译文": "黄云千里日色昏暗，北风吹雁大雪纷纷。不要担心前路无知己，天下有谁不认识您呢？", "注释": "- **董大**：董庭兰，唐代著名琴师。\n- **曛**：昏暗。", "赏析": "此诗是送别诗中的豪放之作。以天下谁人不识君勉励朋友，豪迈慷慨，一扫送别诗的悲酸之态。", "作者": "高适（约704年－765年），字达夫，唐代边塞诗人。与岑参并称高岑。"}}, {"title": "卜算子·咏梅", "poet": "毛泽东", "dynasty": "近现代", "type": "词", "theme": "咏物", "tags": ["咏物", "梅花", "词"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["风雨送春归，飞雪迎春到。已是悬崖百丈冰，犹有花枝俏。俏也不争春，只把春来报。待到山花烂漫时，她在丛中笑。"], "ruby": [[["风", "fēng"], ["雨", "yǔ"], ["送", "sòng"], ["春", "chūn"], ["归", "guī"], ["，", ""], ["飞", "fēi"], ["雪", "xuě"], ["迎", "yíng"], ["春", "chūn"], ["到", "dào"], ["。", ""], ["已", "yǐ"], ["是", "shì"], ["悬", "xuán"], ["崖", "yá"], ["百", "bǎi"], ["丈", "zhàng"], ["冰", "bīng"], ["，", ""], ["犹", "yóu"], ["有", "yǒu"], ["花", "huā"], ["枝", "zhī"], ["俏", "qiào"], ["。", ""], ["俏", "qiào"], ["也", "yě"], ["不", "bù"], ["争", "zhēng"], ["春", "chūn"], ["，", ""], ["只", "zhǐ"], ["把", "bǎ"], ["春", "chūn"], ["来", "lái"], ["报", "bào"], ["。", ""], ["待", "dài"], ["到", "dào"], ["山", "shān"], ["花", "huā"], ["烂", "làn"], ["漫", "màn"], ["时", "shí"], ["，", ""], ["她", "tā"], ["在", "zài"], ["丛", "cóng"], ["中", "zhōng"], ["笑", "xiào"], ["。", ""]]], "sections": {"译文": "风雨送春飞雪迎春，悬崖百丈冰仍有梅花俏丽。梅花不争春只把春来报，待到山花烂漫时她在丛中笑。", "注释": "- **俏**：俊俏美丽。\n- **烂漫**：色彩鲜艳繁盛。", "赏析": "反陆游词意而用之，塑造了乐观谦逊的梅花形象。待到山花烂漫时她在丛中笑展现了革命者的乐观主义精神。", "作者": "毛泽东（1893年－1976年），字润之，中国无产阶级革命家、诗人。"}}, {"title": "四时田园杂兴（其二）", "poet": "范成大", "dynasty": "宋", "type": "七言绝句", "theme": "田园", "tags": ["田园", "农村", "夏天"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["梅子金黄杏子肥，", "麦花雪白菜花稀。", "日长篱落无人过，", "惟有蜻蜓蛱蝶飞。"], "ruby": [[["梅", "méi"], ["子", "zi"], ["金", "jīn"], ["黄", "huáng"], ["杏", "xìng"], ["子", "zi"], ["肥", "féi"], ["，", ""]], [["麦", "mài"], ["花", "huā"], ["雪", "xuě"], ["白", "bái"], ["菜", "cài"], ["花", "huā"], ["稀", "xī"], ["。", ""]], [["日", "rì"], ["长", "zhǎng"], ["篱", "lí"], ["落", "luò"], ["无", "wú"], ["人", "rén"], ["过", "guò"], ["，", ""]], [["惟", "wéi"], ["有", "yǒu"], ["蜻", "qīng"], ["蜓", "tíng"], ["蛱", "jiá"], ["蝶", "dié"], ["飞", "fēi"], ["。", ""]]], "sections": {"译文": "梅子金黄杏子肥美，荞麦花雪白菜花稀疏。白天变长篱边无人过，只有蜻蜓蛱蝶飞舞。", "注释": "- **蛱蝶**：蝴蝶的一种。", "赏析": "此诗描写初夏江南田园的宁静。以蜻蜓蛱蝶飞舞衬人静，意境清幽。", "作者": "范成大（1126年－1193年），号石湖居士，南宋诗人，南宋四大家之一。"}}, {"title": "塞下曲", "poet": "卢纶", "dynasty": "唐", "type": "五言绝句", "theme": "边塞", "tags": ["边塞", "战争", "豪迈"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["月黑雁飞高，", "单于夜遁逃。", "欲将轻骑逐，", "大雪满弓刀。"], "ruby": [[["月", "yuè"], ["黑", "hēi"], ["雁", "yàn"], ["飞", "fēi"], ["高", "gāo"], ["，", ""]], [["单", "dān"], ["于", "yú"], ["夜", "yè"], ["遁", "dùn"], ["逃", "táo"], ["。", ""]], [["欲", "yù"], ["将", "jiāng"], ["轻", "qīng"], ["骑", "qí"], ["逐", "zhú"], ["，", ""]], [["大", "dà"], ["雪", "xuě"], ["满", "mǎn"], ["弓", "gōng"], ["刀", "dāo"], ["。", ""]]], "sections": {"译文": "月黑雁高飞，单于趁夜逃。正要率轻骑追击，大雪落满弓刀。", "注释": "- **单于**：匈奴首领。\n- **轻骑**：轻装骑兵。", "赏析": "此诗写边塞追击场景。大雪满弓刀以景结情，渲染肃杀与豪迈。", "作者": "卢纶（约737年－约799年），大历十才子之一。"}}, {"title": "墨梅", "poet": "王冕", "dynasty": "元", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "梅花", "气节"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["吾家洗砚池头树，", "个个花开淡墨痕。", "不要人夸好颜色，", "只留清气满乾坤。"], "ruby": [[["吾", "wú"], ["家", "jiā"], ["洗", "xǐ"], ["砚", "yàn"], ["池", "chí"], ["头", "tóu"], ["树", "shù"], ["，", ""]], [["个", "gè"], ["个", "gè"], ["花", "huā"], ["开", "kāi"], ["淡", "dàn"], ["墨", "mò"], ["痕", "hén"], ["。", ""]], [["不", "bù"], ["要", "yào"], ["人", "rén"], ["夸", "kuā"], ["好", "hǎo"], ["颜", "yán"], ["色", "sè"], ["，", ""]], [["只", "zhǐ"], ["留", "liú"], ["清", "qīng"], ["气", "qì"], ["满", "mǎn"], ["乾", "qián"], ["坤", "kūn"], ["。", ""]]], "sections": {"译文": "我家洗砚池边有梅树，朵朵梅花有淡墨痕。不需要人夸颜色好，只留清香充满天地间。", "注释": "- **洗砚池**：洗笔砚的水池。\n- **清气**：清香，也指清高品格。", "赏析": "此诗以墨梅咏怀。不要人夸好颜色，只留清气满乾坤表达了不慕虚荣追求精神高洁的人生态度。", "作者": "王冕（1287年－1359年），字元章，元末画家诗人。"}}, {"title": "夏日绝句", "poet": "李清照", "dynasty": "宋", "type": "五言绝句", "theme": "爱国", "tags": ["爱国", "咏史", "气节"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["生当作人杰，", "死亦为鬼雄。", "至今思项羽，", "不肯过江东。"], "ruby": [[["生", "shēng"], ["当", "dāng"], ["作", "zuò"], ["人", "rén"], ["杰", "jié"], ["，", ""]], [["死", "sǐ"], ["亦", "yì"], ["为", "wèi"], ["鬼", "guǐ"], ["雄", "xióng"], ["。", ""]], [["至", "zhì"], ["今", "jīn"], ["思", "sī"], ["项", "xiàng"], ["羽", "yǔ"], ["，", ""]], [["不", "bù"], ["肯", "kěn"], ["过", "guò"], ["江", "jiāng"], ["东", "dōng"], ["。", ""]]], "sections": {"译文": "活着要做人中豪杰，死了也要做鬼中英雄。至今人们思念项羽，因为他不肯逃回江东。", "注释": "- **人杰**：人中豪杰。\n- **项羽**：西楚霸王，兵败后自刎乌江。", "赏析": "此诗借古讽今，以项羽宁死不屈的气节讽刺南宋朝廷的懦弱苟安。慷慨激昂掷地有声。", "作者": "李清照（1084年－约1155年），号易安居士，宋代女词人，婉约派代表。"}}, {"title": "嫦娥", "poet": "李商隐", "dynasty": "唐", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "神话", "孤独"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["云母屏风烛影深，", "长河渐落晓星沉。", "嫦娥应悔偷灵药，", "碧海青天夜夜心。"], "ruby": [[["云", "yún"], ["母", "mǔ"], ["屏", "píng"], ["风", "fēng"], ["烛", "zhú"], ["影", "yǐng"], ["深", "shēn"], ["，", ""]], [["长", "cháng"], ["河", "hé"], ["渐", "jiàn"], ["落", "luò"], ["晓", "xiǎo"], ["星", "xīng"], ["沉", "chén"], ["。", ""]], [["嫦", "cháng"], ["娥", "é"], ["应", "yīng"], ["悔", "huǐ"], ["偷", "tōu"], ["灵", "líng"], ["药", "yào"], ["，", ""]], [["碧", "bì"], ["海", "hǎi"], ["青", "qīng"], ["天", "tiān"], ["夜", "yè"], ["夜", "yè"], ["心", "xīn"], ["。", ""]]], "sections": {"译文": "云母屏风上映着幽深烛影，银河西落晨星隐没。嫦娥应悔偷吃了灵药，如今在碧海青天中夜夜孤独。", "注释": "- **长河**：银河。\n- **灵药**：长生不老药。", "赏析": "此诗借嫦娥奔月抒写孤独之情。以应悔的揣测写嫦娥寂寞，实则是借嫦娥自喻。", "作者": "李商隐（约813年－约858年），字义山，号玉溪生，唐代诗人。"}}, {"title": "宿新市徐公店", "poet": "杨万里", "dynasty": "宋", "type": "七言绝句", "theme": "春天", "tags": ["春天", "童趣", "农村"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["篱落疏疏一径深，", "树头新绿未成阴。", "儿童急走追黄蝶，", "飞入菜花无处寻。"], "ruby": [[["篱", "lí"], ["落", "luò"], ["疏", "shū"], ["疏", "shū"], ["一", ""], ["径", "jìng"], ["深", "shēn"], ["，", ""]], [["树", "shù"], ["头", "tóu"], ["新", "xīn"], ["绿", "lǜ"], ["未", "wèi"], ["成", "chéng"], ["阴", "yīn"], ["。", ""]], [["儿", "ér"], ["童", "tóng"], ["急", "jí"], ["走", "zǒu"], ["追", "zhuī"], ["黄", "huáng"], ["蝶", "dié"], ["，", ""]], [["飞", "fēi"], ["入", "rù"], ["菜", "cài"], ["花", "huā"], ["无", "wú"], ["处", "chù"], ["寻", "xún"], ["。", ""]]], "sections": {"译文": "篱笆稀疏小路伸向远方，树头新绿未成荫。小孩跑着追黄蝴蝶，蝴蝶飞入菜花中没法找了。", "注释": "- **篱落**：篱笆。\n- **阴**：树荫。", "赏析": "此诗写春景之趣。儿童追蝶无处寻，蝶花难辨妙趣横生。", "作者": "杨万里（1127年－1206年），字廷秀，号诚斋，南宋诗人。"}}, {"title": "暮江吟", "poet": "白居易", "dynasty": "唐", "type": "七言绝句", "theme": "写景", "tags": ["写景", "傍晚", "月亮"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["一道残阳铺水中，", "半江瑟瑟半江红。", "可怜九月初三夜，", "露似真珠月似弓。"], "ruby": [[["一", ""], ["道", "dào"], ["残", "cán"], ["阳", "yáng"], ["铺", "pū"], ["水", "shuǐ"], ["中", "zhōng"], ["，", ""]], [["半", "bàn"], ["江", "jiāng"], ["瑟", "sè"], ["瑟", "sè"], ["半", "bàn"], ["江", "jiāng"], ["红", "hóng"], ["。", ""]], [["可", "kě"], ["怜", "lián"], ["九", "jiǔ"], ["月", "yuè"], ["初", "chū"], ["三", "sān"], ["夜", "yè"], ["，", ""]], [["露", "lù"], ["似", "sì"], ["真", "zhēn"], ["珠", "zhū"], ["月", "yuè"], ["似", "sì"], ["弓", "gōng"], ["。", ""]]], "sections": {"译文": "一道残阳斜照在江面上，使江水一半呈碧绿色一半呈红色。九月初三的夜晚多么可爱，露水像珍珠一样圆润，月亮像弯弓一样纤细。", "注释": "- **残阳**：快要落山的太阳。\n- **瑟瑟**：碧绿色。\n- **可怜**：可爱。\n- **真珠**：珍珠。", "赏析": "前两句写夕阳下的江景，\"残阳铺水中\"一个\"铺\"字写出夕阳斜照之态；\"半江瑟瑟半江红\"以色彩的明暗对比写出江面之美。后两句转写夜晚，露如珠、月如弓，两个比喻清新可喜，写出初三夜特有的可爱景象。", "作者": "白居易（772年－846年），字乐天，号香山居士，唐代伟大的现实主义诗人。"}}, {"title": "浪淘沙", "poet": "刘禹锡", "dynasty": "唐", "type": "七言绝句", "theme": "黄河", "tags": ["黄河", "写景", "神话"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["九曲黄河万里沙，", "浪淘风簸自天涯。", "如今直上银河去，", "同到牵牛织女家。"], "ruby": [[["九", "jiǔ"], ["曲", "qū"], ["黄", "huáng"], ["河", "hé"], ["万", "wàn"], ["里", "lǐ"], ["沙", "shā"], ["，", ""]], [["浪", "làng"], ["淘", "táo"], ["风", "fēng"], ["簸", "bǒ"], ["自", "zì"], ["天", "tiān"], ["涯", "yá"], ["。", ""]], [["如", "rú"], ["今", "jīn"], ["直", "zhí"], ["上", "shàng"], ["银", "yín"], ["河", "hé"], ["去", "qù"], ["，", ""]], [["同", "tóng"], ["到", "dào"], ["牵", "qiān"], ["牛", "niú"], ["织", "zhī"], ["女", "nǚ"], ["家", "jiā"], ["。", ""]]], "sections": {"译文": "弯弯曲曲的黄河挟带万里泥沙，巨浪淘洗来自天边。我要沿着黄河直上银河，同到牵牛织女家做客。", "注释": "- **九曲**：形容黄河河道弯曲。\n- **浪淘风簸**：巨浪淘洗狂风颠簸。", "赏析": "此诗以神奇想象写黄河壮阔。将黄河与银河相连，想象奇特气魄宏大。", "作者": "刘禹锡（772年－842年），字梦得，唐代诗人、文学家。"}}, {"title": "清平乐·村居", "poet": "辛弃疾", "dynasty": "宋", "type": "词", "theme": "田园", "tags": ["田园", "词", "农村"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["茅檐低小，溪上青青草。醉里吴音相媚好，白发谁家翁媪？大儿锄豆溪东，中儿正织鸡笼。最喜小儿亡赖，溪头卧剥莲蓬。"], "ruby": [[["茅", "máo"], ["檐", "yán"], ["低", "dī"], ["小", "xiǎo"], ["，", ""], ["溪", "xī"], ["上", "shàng"], ["青", "qīng"], ["青", "qīng"], ["草", "cǎo"], ["。", ""], ["醉", "zuì"], ["里", "lǐ"], ["吴", "wú"], ["音", "yīn"], ["相", "xiāng"], ["媚", "mèi"], ["好", "hǎo"], ["，", ""], ["白", "bái"], ["发", "fā"], ["谁", "shuí"], ["家", "jiā"], ["翁", "wēng"], ["媪", "ǎo"], ["？", ""], ["大", "dà"], ["儿", "ér"], ["锄", "chú"], ["豆", "dòu"], ["溪", "xī"], ["东", "dōng"], ["，", ""], ["中", "zhōng"], ["儿", "ér"], ["正", "zhèng"], ["织", "zhī"], ["鸡", "jī"], ["笼", "lóng"], ["。", ""], ["最", "zuì"], ["喜", "xǐ"], ["小", "xiǎo"], ["儿", "ér"], ["亡", "wáng"], ["赖", "lài"], ["，", ""], ["溪", "xī"], ["头", "tóu"], ["卧", "wò"], ["剥", "bō"], ["莲", "lián"], ["蓬", "péng"], ["。", ""]]], "sections": {"译文": "茅屋低小溪边长满青草。醉意的吴语互相逗趣是谁家的老翁老妇？大儿锄豆二儿织鸡笼，小儿卧在溪边剥莲蓬。", "注释": "- **吴音**：吴地方言。\n- **翁媪**：老翁和老妇。\n- **亡赖**：顽皮可爱。", "赏析": "此词以白描勾勒农村生活画卷。小儿卧剥莲蓬的细节天真烂漫，生动传神。", "作者": "辛弃疾（1140年－1207年），字幼安，号稼轩，南宋豪放派词人。"}}, {"title": "独坐敬亭山", "poet": "李白", "dynasty": "唐", "type": "五言绝句", "theme": "山水", "tags": ["山水", "孤独", "李白"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["众鸟高飞尽，", "孤云独去闲。", "相看两不厌，", "只有敬亭山。"], "ruby": [[["众", "zhòng"], ["鸟", "niǎo"], ["高", "gāo"], ["飞", "fēi"], ["尽", "jǐn"], ["，", ""]], [["孤", "gū"], ["云", "yún"], ["独", "dú"], ["去", "qù"], ["闲", "xián"], ["。", ""]], [["相", "xiāng"], ["看", "kàn"], ["两", "liǎng"], ["不", "bù"], ["厌", "yàn"], ["，", ""]], [["只", "zhǐ"], ["有", "yǒu"], ["敬", "jìng"], ["亭", "tíng"], ["山", "shān"], ["。", ""]]], "sections": {"译文": "群鸟高飞去无踪影，孤云独立悠闲飘走。只有我和敬亭山相看两不厌。", "注释": "- **敬亭山**：在今安徽宣城。\n- **闲**：悠闲。", "赏析": "此诗写独坐敬亭山时的孤寂。相看两不厌将山水拟人化，物我交融，写出了极致的孤独。", "作者": "李白（701年－762年），字太白，号青莲居士，唐代伟大的浪漫主义诗人。"}}, {"title": "王戎不取道旁李", "poet": "《世说新语》", "dynasty": "南朝", "type": "文言文", "theme": "智慧", "tags": ["智慧", "文言文", "哲理"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["王戎七岁，尝与诸小儿游。看道边李树多子折枝，诸儿竞走取之，唯戎不动。人问之，答曰：树在道边而多子，此必苦李。取之，信然。"], "ruby": [[["王", "wáng"], ["戎", "róng"], ["七", "qī"], ["岁", "suì"], ["，", ""], ["尝", "cháng"], ["与", "yǔ"], ["诸", "zhū"], ["小", "xiǎo"], ["儿", "ér"], ["游", "yóu"], ["。", ""], ["看", "kàn"], ["道", "dào"], ["边", "biān"], ["李", "lǐ"], ["树", "shù"], ["多", "duō"], ["子", "zi"], ["折", "zhé"], ["枝", "zhī"], ["，", ""], ["诸", "zhū"], ["儿", "ér"], ["竞", "jìng"], ["走", "zǒu"], ["取", "qǔ"], ["之", "zhī"], ["，", ""], ["唯", "wéi"], ["戎", "róng"], ["不", "bù"], ["动", "dòng"], ["。", ""], ["人", "rén"], ["问", "wèn"], ["之", "zhī"], ["，", ""], ["答", "dá"], ["曰", "yuē"], ["：", ""], ["树", "shù"], ["在", "zài"], ["道", "dào"], ["边", "biān"], ["而", "ér"], ["多", "duō"], ["子", "zi"], ["，", ""], ["此", "cǐ"], ["必", "bì"], ["苦", "kǔ"], ["李", "lǐ"], ["。", ""], ["取", "qǔ"], ["之", "zhī"], ["，", ""], ["信", "xìn"], ["然", "rán"], ["。", ""]]], "sections": {"译文": "王戎七岁时和小孩们玩耍。路旁李树结满果实，孩子们都争着去摘，只有王戎不动。他说树在路边却这么多果子一定是苦的。一尝果然如此。", "注释": "- **尝**：曾经。\n- **竞走**：争相跑去。\n- **信然**：果然这样。", "赏析": "通过王戎幼年的故事表现他善于观察推理的品质，展示了独立思考的智慧。", "作者": "本文选自《世说新语·雅量》。"}}, {"title": "精卫填海", "poet": "《山海经》", "dynasty": "先秦", "type": "文言文", "theme": "神话", "tags": ["神话", "励志", "文言文"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["炎帝之少女，名曰女娃。女娃游于东海，溺而不返，故为精卫，常衔西山之木石，以堙于东海。"], "ruby": [[["炎", "yán"], ["帝", "dì"], ["之", "zhī"], ["少", "shǎo"], ["女", "nǚ"], ["，", ""], ["名", "míng"], ["曰", "yuē"], ["女", "nǚ"], ["娃", "wá"], ["。", ""], ["女", "nǚ"], ["娃", "wá"], ["游", "yóu"], ["于", "yú"], ["东", "dōng"], ["海", "hǎi"], ["，", ""], ["溺", "nì"], ["而", "ér"], ["不", "bù"], ["返", "fǎn"], ["，", ""], ["故", "gù"], ["为", "wèi"], ["精", "jīng"], ["卫", "wèi"], ["，", ""], ["常", "cháng"], ["衔", "xián"], ["西", "xī"], ["山", "shān"], ["之", "zhī"], ["木", "mù"], ["石", "shí"], ["，", ""], ["以", "yǐ"], ["堙", "yīn"], ["于", "yú"], ["东", "dōng"], ["海", "hǎi"], ["。", ""]]], "sections": {"译文": "炎帝的小女儿女娃在东海游玩淹死，化为精卫鸟，常常衔西山的木石来填塞东海。", "注释": "- **少女**：小女儿。\n- **溺**：淹死。\n- **堙**：填塞。", "赏析": "精卫填海体现了不屈不挠的坚韧精神。精卫虽身小力微却坚持不懈衔石填海，意志感人。", "作者": "本文选自《山海经·北山经》。"}}, {"title": "芙蓉楼送辛渐", "poet": "王昌龄", "dynasty": "唐", "type": "七言绝句", "theme": "送别", "tags": [], "grade": "05-四年级", "grade_label": "四年级", "lines": [], "ruby": [], "sections": {"译文": "", "注释": "", "赏析": "", "作者": ""}}, {"title": "蜂", "poet": "罗隐", "dynasty": "唐", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "劳动", "讽刺"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["不论平地与山尖，", "无限风光尽被占。", "采得百花成蜜后，", "为谁辛苦为谁甜？"], "ruby": [[["不", "bù"], ["论", "lùn"], ["平", "píng"], ["地", "dì"], ["与", "yǔ"], ["山", "shān"], ["尖", "jiān"], ["，", ""]], [["无", "wú"], ["限", "xiàn"], ["风", "fēng"], ["光", "guāng"], ["尽", "jǐn"], ["被", "bèi"], ["占", "zhàn"], ["。", ""]], [["采", "cǎi"], ["得", "dé"], ["百", "bǎi"], ["花", "huā"], ["成", "chéng"], ["蜜", "mì"], ["后", "hòu"], ["，", ""]], [["为", "wèi"], ["谁", "shuí"], ["辛", "xīn"], ["苦", "kǔ"], ["为", "wèi"], ["谁", "shuí"], ["甜", "tián"], ["？", ""]]], "sections": {"译文": "无论在平地还是山顶无限风光都被蜂占，采尽百花酿成蜜后为谁辛苦为谁甜？", "注释": "- **山尖**：山顶。", "赏析": "此诗以蜜蜂为喻赞美劳动者，暗讽不劳而获。为谁辛苦为谁甜引人深思。", "作者": "罗隐（833年－909年），字昭谏，唐代诗人。"}}, {"title": "雪梅", "poet": "卢梅坡", "dynasty": "宋", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "雪", "梅花"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["梅雪争春未肯降，", "骚人阁笔费评章。", "梅须逊雪三分白，", "雪却输梅一段香。"], "ruby": [[["梅", "méi"], ["雪", "xuě"], ["争", "zhēng"], ["春", "chūn"], ["未", "wèi"], ["肯", "kěn"], ["降", "xiáng"], ["，", ""]], [["骚", "sāo"], ["人", "rén"], ["阁", "gé"], ["笔", "bǐ"], ["费", "fèi"], ["评", "píng"], ["章", "zhāng"], ["。", ""]], [["梅", "méi"], ["须", "xū"], ["逊", "xùn"], ["雪", "xuě"], ["三", "sān"], ["分", "fēn"], ["白", "bái"], ["，", ""]], [["雪", "xuě"], ["却", "què"], ["输", "shū"], ["梅", "méi"], ["一", ""], ["段", "duàn"], ["香", "xiāng"], ["。", ""]]], "sections": {"译文": "梅花和雪花争春谁也不肯认输，诗人放下笔费尽心思来品评。梅花比起雪来还差三分洁白，雪却比梅花少了一段清香。", "注释": "- **降**：认输，投降。\n- **骚人**：诗人。\n- **阁**：同\"搁\"，放下。\n- **评章**：评议，品评。\n- **逊**：不及，差。", "赏析": "这首咏物诗想象新奇，将梅雪拟人化\"争春\"，诗人设为\"评委\"。后两句以辩证眼光评出高下：\"梅须逊雪三分白，雪却输梅一段香\"——各有所长，各有所短，含蓄地表达了\"尺有所短，寸有所长\"的哲理。", "作者": "卢梅坡，南宋诗人，生卒年不详。其《雪梅》二首传世。"}}, {"title": "题西林壁", "poet": "苏轼", "dynasty": "宋", "type": "七言绝句", "theme": "哲理", "tags": ["哲理", "庐山", "写景"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["横看成岭侧成峰，", "远近高低各不同。", "不识庐山真面目，", "只缘身在此山中。"], "ruby": [[["横", "héng"], ["看", "kàn"], ["成", "chéng"], ["岭", "lǐng"], ["侧", "cè"], ["成", "chéng"], ["峰", "fēng"], ["，", ""]], [["远", "yuǎn"], ["近", "jìn"], ["高", "gāo"], ["低", "dī"], ["各", "gè"], ["不", "bù"], ["同", "tóng"], ["。", ""]], [["不", "bù"], ["识", "shí"], ["庐", "lú"], ["山", "shān"], ["真", "zhēn"], ["面", "miàn"], ["目", "mù"], ["，", ""]], [["只", "zhǐ"], ["缘", "yuán"], ["身", "shēn"], ["在", "zài"], ["此", "cǐ"], ["山", "shān"], ["中", "zhōng"], ["。", ""]]], "sections": {"译文": "从正面看庐山是连绵的山岭，从侧面看是陡峭的山峰，从远、近、高、低不同角度看各不相同。看不清庐山的真面目，只因为我就身在这座山里。", "注释": "- **题**：书写，题写。\n- **西林壁**：西林寺的墙壁。西林寺在庐山。\n- **横看**：从正面看。\n- **缘**：因为。", "赏析": "前两句写庐山从不同角度看千姿百态，后两句由此生发哲理：身处山中反看不真切，恰如\"当局者迷，旁观者清\"。全诗写景中说理，理在景中，是宋诗\"理趣\"的代表作。", "作者": "苏轼（1037年－1101年），字子瞻，号东坡居士，北宋文学家、书画家。"}}, {"title": "鹿柴", "poet": "王维", "dynasty": "唐", "type": "五言绝句", "theme": "山水", "tags": ["山水", "写景", "空灵"], "grade": "05-四年级", "grade_label": "四年级", "lines": ["空山不见人，", "但闻人语响。", "返景入深林，", "复照青苔上。"], "ruby": [[["空", "kōng"], ["山", "shān"], ["不", "bù"], ["见", "jiàn"], ["人", "rén"], ["，", ""]], [["但", "dàn"], ["闻", "wén"], ["人", "rén"], ["语", "yǔ"], ["响", "xiǎng"], ["。", ""]], [["返", "fǎn"], ["景", "jǐng"], ["入", "rù"], ["深", "shēn"], ["林", "lín"], ["，", ""]], [["复", "fù"], ["照", "zhào"], ["青", "qīng"], ["苔", "tái"], ["上", "shàng"], ["。", ""]]], "sections": {"译文": "空寂的山中看不到人，只隐约听到人语声。落日照入深林，又映照在青苔上。", "注释": "- **鹿柴**：辋川别墅中的一处景点。\n- **返景**：夕阳返照的光。", "赏析": "此诗以动衬静以光写幽。空山不见人写静，人语响更衬其静；返景入深林写暗，一抹斜阳反衬深山幽邃。", "作者": "王维（约701年－761年），字摩诘，唐代诗人、画家。"}}]}