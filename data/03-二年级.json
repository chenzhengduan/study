{"grade": "03-二年级", "label": "二年级", "count": 13, "poems": [{"title": "咏柳", "poet": "贺知章", "dynasty": "唐", "type": "七言绝句", "theme": "咏物", "tags": ["咏物", "春天", "柳树"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["碧玉妆成一树高，", "万条垂下绿丝绦。", "不知细叶谁裁出，", "二月春风似剪刀。"], "ruby": [[["碧", "bì"], ["玉", "yù"], ["妆", "zhuāng"], ["成", "chéng"], ["一", ""], ["树", "shù"], ["高", "gāo"], ["，", ""]], [["万", "wàn"], ["条", "tiáo"], ["垂", "chuí"], ["下", "xià"], ["绿", "lǜ"], ["丝", "sī"], ["绦", "tāo"], ["。", ""]], [["不", "bù"], ["知", "zhī"], ["细", "xì"], ["叶", "yè"], ["谁", "shuí"], ["裁", "cái"], ["出", "chū"], ["，", ""]], [["二", "èr"], ["月", "yuè"], ["春", "chūn"], ["风", "fēng"], ["似", "shì"], ["剪", "jiǎn"], ["刀", "dāo"], ["。", ""]]], "sections": {"译文": "像碧玉妆点成高高的柳树，万条柳枝垂下像绿色的丝带。不知细叶谁裁出，原来是二月春风像剪刀裁出来的。", "注释": "- **妆**：装饰。\n- **丝绦**：丝带。", "赏析": "此诗以巧妙的比喻咏柳。以剪刀喻春风，将无形的春风化为有形的剪裁，想象新奇。", "作者": "贺知章（约659年－约744年），字季真，唐代诗人、书法家。"}}, {"title": "夜宿山寺", "poet": "李白", "dynasty": "唐", "type": "五言绝句", "theme": "写景", "tags": ["写景", "山寺", "夸张"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["危楼高百尺，", "手可摘星辰。", "不敢高声语，", "恐惊天上人。"], "ruby": [[["危", "wēi"], ["楼", "lóu"], ["高", "gāo"], ["百", "bǎi"], ["尺", "chǐ"], ["，", ""]], [["手", "shǒu"], ["可", "kě"], ["摘", "zhāi"], ["星", "xīng"], ["辰", "chén"], ["。", ""]], [["不", "bù"], ["敢", "gǎn"], ["高", "gāo"], ["声", "shēng"], ["语", "yǔ"], ["，", ""]], [["恐", "kǒng"], ["惊", "jīng"], ["天", "tiān"], ["上", "shàng"], ["人", "rén"], ["。", ""]]], "sections": {"译文": "山上的高楼有百尺之高，站在上面伸手就能摘到星辰。我不敢大声说话，恐怕惊动天上的仙人。", "注释": "- **危楼**：高楼。危，高。\n- **星辰**：天上的星星。", "赏析": "此诗用极度夸张的手法写山寺之高。不敢高声语，恐惊天上人更是将奇特的想象发挥到极致。", "作者": "李白（701年－762年），字太白，号青莲居士，唐代伟大的浪漫主义诗人，被后人誉为诗仙。"}}, {"title": "小儿垂钓", "poet": "胡令能", "dynasty": "唐", "type": "七言绝句", "theme": "童趣", "tags": ["童趣", "儿童", "垂钓"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["蓬头稚子学垂纶，", "侧坐莓苔草映身。", "路人借问遥招手，", "怕得鱼惊不应人。"], "ruby": [[["蓬", "péng"], ["头", "tóu"], ["稚", "zhì"], ["子", "zi"], ["学", "xué"], ["垂", "chuí"], ["纶", "lún"], ["，", ""]], [["侧", "cè"], ["坐", "zuò"], ["莓", "méi"], ["苔", "tái"], ["草", "cǎo"], ["映", "yìng"], ["身", "shēn"], ["。", ""]], [["路", "lù"], ["人", "rén"], ["借", "jiè"], ["问", "wèn"], ["遥", "yáo"], ["招", "zhāo"], ["手", "shǒu"], ["，", ""]], [["怕", "pà"], ["得", "dé"], ["鱼", "yú"], ["惊", "jīng"], ["不", "bù"], ["应", "yìng"], ["人", "rén"], ["。", ""]]], "sections": {"译文": "一个头发蓬乱的小孩在学钓鱼，侧身坐在莓苔上。路人来问路，他远远地招手示意，怕惊动了鱼儿不敢应答。", "注释": "- **蓬头**：头发蓬乱。\n- **稚子**：小孩子。\n- **垂纶**：钓鱼。", "赏析": "此诗刻画了一个天真可爱的儿童形象。蓬头侧坐写其形，遥招手不应人传其神，生动传神。", "作者": "胡令能（生卒年不详），唐代诗人，隐居莆田。"}}, {"title": "敕勒歌", "poet": "北朝民歌", "dynasty": "北朝", "type": "乐府诗", "theme": "草原", "tags": ["草原", "民歌", "写景"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["敕勒川，阴山下。", "天似穹庐，笼盖四野。", "天苍苍，野茫茫，", "风吹草低见牛羊。"], "ruby": [[["敕", "chì"], ["勒", "lēi"], ["川", "chuān"], ["，", ""], ["阴", "yīn"], ["山", "shān"], ["下", "xià"], ["。", ""]], [["天", "tiān"], ["似", "shì"], ["穹", "qióng"], ["庐", "lú"], ["，", ""], ["笼", "lóng"], ["盖", "gài"], ["四", "sì"], ["野", "yě"], ["。", ""]], [["天", "tiān"], ["苍", "cāng"], ["苍", "cāng"], ["，", ""], ["野", "yě"], ["茫", "máng"], ["茫", "máng"], ["，", ""]], [["风", "fēng"], ["吹", "chuī"], ["草", "cǎo"], ["低", "dī"], ["见", "xiàn"], ["牛", "niú"], ["羊", "yáng"], ["。", ""]]], "sections": {"译文": "敕勒平原，在阴山脚下。天空像巨大的帐篷笼罩着原野。风吹过草低处，露出了成群的牛羊。", "注释": "- **敕勒**：北朝时北方的游牧民族。\n- **川**：平原。\n- **穹庐**：游牧民族居住的帐篷。\n- **见**：同现，露出。", "赏析": "这首北朝民歌用简练质朴的语言描绘了草原壮丽辽阔的景象。天似穹庐写天地相接的壮观，风吹草低见牛羊展现草原的生机。", "作者": "敕勒歌是北朝敕勒族的民歌，最早收录于《乐府诗集》。"}}, {"title": "晓出净慈寺送林子方", "poet": "杨万里", "dynasty": "宋", "type": "七言绝句", "theme": "写景", "tags": [], "grade": "03-二年级", "grade_label": "二年级", "lines": ["毕竟西湖六月中，", "风光不与四时同。", "接天莲叶无穷碧，", "映日荷花别样红。"], "ruby": [[["毕", "bì"], ["竟", "jìng"], ["西", "xī"], ["湖", "hú"], ["六", "liù"], ["月", "yuè"], ["中", "zhōng"], ["，", ""]], [["风", "fēng"], ["光", "guāng"], ["不", "bù"], ["与", "yǔ"], ["四", "sì"], ["时", "shí"], ["同", "tóng"], ["。", ""]], [["接", "jiē"], ["天", "tiān"], ["莲", "lián"], ["叶", "yè"], ["无", "wú"], ["穷", "qióng"], ["碧", "bì"], ["，", ""]], [["映", "yìng"], ["日", "rì"], ["荷", "hé"], ["花", "huā"], ["别", "bié"], ["样", "yàng"], ["红", "hóng"], ["。", ""]]], "sections": {"译文": "到底是六月的西湖，风光与别的时节都不同。接天的莲叶碧绿无边，映日的荷花红得格外不同。", "注释": "- **毕竟**：到底。\n- **四时**：春夏秋冬四季。\n- **别样**：特别、不同寻常。", "赏析": "“接天莲叶无穷碧，映日荷花别样红”写尽西湖盛夏荷景，色彩绚丽，气象开阔，为咏荷名句。", "作者": "杨万里（1127年－1206年），字廷秀，号诚斋，南宋诗人。"}}, {"title": "望庐山瀑布", "poet": "李白", "dynasty": "唐", "type": "七言绝句", "theme": "山水", "tags": ["山水", "庐山", "瀑布"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["日照香炉生紫烟，", "遥看瀑布挂前川。", "飞流直下三千尺，", "疑是银河落九天。"], "ruby": [[["日", "rì"], ["照", "zhào"], ["香", "xiāng"], ["炉", "lú"], ["生", "shēng"], ["紫", "zǐ"], ["烟", "yān"], ["，", ""]], [["遥", "yáo"], ["看", "kàn"], ["瀑", "pù"], ["布", "bù"], ["挂", "guà"], ["前", "qián"], ["川", "chuān"], ["。", ""]], [["飞", "fēi"], ["流", "liú"], ["直", "zhí"], ["下", "xià"], ["三", "sān"], ["千", "qiān"], ["尺", "chǐ"], ["，", ""]], [["疑", "yí"], ["是", "shì"], ["银", "yín"], ["河", "hé"], ["落", "luò"], ["九", "jiǔ"], ["天", "tiān"], ["。", ""]]], "sections": {"译文": "阳光照耀着香炉峰升起紫色烟霞；远远望去瀑布像白布挂在山前。飞流直下三千尺，让人怀疑是银河从九天倾泻下来。", "注释": "- **香炉**：庐山的香炉峰。\n- **九天**：古人认为天有九重。", "赏析": "此诗以极度夸张的手法描绘庐山瀑布的壮美。飞流直下三千尺与疑是银河落九天，想象瑰丽奇特，极具浪漫主义色彩。", "作者": "李白（701年－762年），字太白，号青莲居士，唐代伟大的浪漫主义诗人，被后人誉为诗仙。"}}, {"title": "村居", "poet": "高鼎", "dynasty": "清", "type": "七言绝句", "theme": "春天", "tags": ["春天", "童趣", "农村"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["草长莺飞二月天，", "拂堤杨柳醉春烟。", "儿童散学归来早，", "忙趁东风放纸鸢。"], "ruby": [[["草", "cǎo"], ["长", "zhǎng"], ["莺", "yīng"], ["飞", "fēi"], ["二", "èr"], ["月", "yuè"], ["天", "tiān"], ["，", ""]], [["拂", "fú"], ["堤", "dī"], ["杨", "yáng"], ["柳", "liǔ"], ["醉", "zuì"], ["春", "chūn"], ["烟", "yān"], ["。", ""]], [["儿", "ér"], ["童", "tóng"], ["散", "sàn"], ["学", "xué"], ["归", "guī"], ["来", "lái"], ["早", "zǎo"], ["，", ""]], [["忙", "máng"], ["趁", "chèn"], ["东", "dōng"], ["风", "fēng"], ["放", "fàng"], ["纸", "zhǐ"], ["鸢", "yuān"], ["。", ""]]], "sections": {"译文": "早春二月，青草生长黄莺飞舞，杨柳拂堤醉在春烟中。孩子们放学早回家，急忙趁着东风放风筝。", "注释": "- **拂堤**：垂柳拂过堤岸。\n- **纸鸢**：风筝。", "赏析": "此诗描绘了一幅生机盎然的早春图景。儿童放风筝充满童趣和活力，洋溢着对春天的热爱。", "作者": "高鼎（生卒年不详），清代诗人，以这首《村居》最为著名。"}}, {"title": "梅花", "poet": "王安石", "dynasty": "宋", "type": "五言绝句", "theme": "咏物", "tags": ["咏物", "梅花", "冬天"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["墙角数枝梅，", "凌寒独自开。", "遥知不是雪，", "为有暗香来。"], "ruby": [[["墙", "qiáng"], ["角", "jiǎo"], ["数", "shù"], ["枝", "zhī"], ["梅", "méi"], ["，", ""]], [["凌", "líng"], ["寒", "hán"], ["独", "dú"], ["自", "zì"], ["开", "kāi"], ["。", ""]], [["遥", "yáo"], ["知", "zhī"], ["不", "bù"], ["是", "shì"], ["雪", "xuě"], ["，", ""]], [["为", "wèi"], ["有", "yǒu"], ["暗", "àn"], ["香", "xiāng"], ["来", "lái"], ["。", ""]]], "sections": {"译文": "墙角有几枝梅花，在严寒中独自开放。远远就知道那不是雪，因为隐约有幽香飘来。", "注释": "- **凌寒**：冒着严寒。\n- **遥**：远远地。\n- **暗香**：幽香。", "赏析": "此诗以梅花自喻，前两句写不畏严寒的品质，后两句以雪衬梅，突出梅花的洁白与幽香。", "作者": "王安石（1021年－1086年），字介甫，号半山，北宋政治家、文学家，唐宋八大家之一。"}}, {"title": "江雪", "poet": "柳宗元", "dynasty": "唐", "type": "五言绝句", "theme": "山水", "tags": [], "grade": "03-二年级", "grade_label": "二年级", "lines": ["千山鸟飞绝，", "万径人踪灭。", "孤舟蓑笠翁，", "独钓寒江雪。"], "ruby": [[["千", "qiān"], ["山", "shān"], ["鸟", "niǎo"], ["飞", "fēi"], ["绝", "jué"], ["，", ""]], [["万", "wàn"], ["径", "jìng"], ["人", "rén"], ["踪", "zōng"], ["灭", "miè"], ["。", ""]], [["孤", "gū"], ["舟", "zhōu"], ["蓑", "suō"], ["笠", "lì"], ["翁", "wēng"], ["，", ""]], [["独", "dú"], ["钓", "diào"], ["寒", "hán"], ["江", "jiāng"], ["雪", "xuě"], ["。", ""]]], "sections": {"译文": "千山之中飞鸟绝迹，万条路上人踪消失。一只孤舟上披蓑戴笠的老翁，独自在寒江雪中垂钓。", "注释": "- **蓑笠**：蓑衣斗笠，防雨雪的用具。\n- **独钓**：独自垂钓。", "赏析": "以千万之广衬孤独之翁，寒江雪钓写出孤高峻洁、超然物外的情怀，意境冷峭孤绝。", "作者": "柳宗元（773年－819年），字子厚，唐代文学家，“唐宋八大家”之一。"}}, {"title": "登鹳雀楼", "poet": "王之涣", "dynasty": "唐", "type": "五言绝句", "theme": "登高", "tags": ["登高", "写景", "哲理"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["白日依山尽，", "黄河入海流。", "欲穷千里目，", "更上一层楼。"], "ruby": [[["白", "bái"], ["日", "rì"], ["依", "yī"], ["山", "shān"], ["尽", "jìn"], ["，", ""]], [["黄", "huáng"], ["河", "hé"], ["入", "rù"], ["海", "hǎi"], ["流", "liú"], ["。", ""]], [["欲", "yù"], ["穷", "qióng"], ["千", "qiān"], ["里", "lǐ"], ["目", "mù"], ["，", ""]], [["更", "gèng"], ["上", "shàng"], ["一", ""], ["层", "céng"], ["楼", "lóu"], ["。", ""]]], "sections": {"译文": "太阳依着远山渐渐落下，黄河奔流向海。想要看到千里之外的景色，就要再登上一层楼。", "注释": "- **鹳雀楼**：在今山西永济市蒲州古城西，前临黄河。\n- **白日**：夕阳。\n- **依山尽**：沿着山势落下。\n- **穷**：尽，达到极点。", "赏析": "前两句写登楼所见壮阔景象，\"白日依山尽\"写夕阳，\"黄河入海流\"写大河，一高一远，气象雄浑。后两句由景生理，\"欲穷千里目，更上一层楼\"既是登楼实写，又含\"志当高远\"的人生哲理，至今传诵不衰。", "作者": "王之涣（688年－742年），字季凌，唐代诗人。以边塞诗著称，作品多散佚，《全唐诗》仅存六首。"}}, {"title": "绝句", "poet": "杜甫", "dynasty": "唐", "type": "五言绝句", "theme": "春天", "tags": ["写景", "春天", "杜甫"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["两个黄鹂鸣翠柳，", "一行白鹭上青天。", "窗含西岭千秋雪，", "门泊东吴万里船。"], "ruby": [[["两", "liǎng"], ["个", "gè"], ["黄", "huáng"], ["鹂", "lí"], ["鸣", "míng"], ["翠", "cuì"], ["柳", "liǔ"], ["，", ""]], [["一", ""], ["行", "háng"], ["白", "bái"], ["鹭", "lù"], ["上", "shàng"], ["青", "qīng"], ["天", "tiān"], ["。", ""]], [["窗", "chuāng"], ["含", "hán"], ["西", "xī"], ["岭", "lǐng"], ["千", "qiān"], ["秋", "qiū"], ["雪", "xuě"], ["，", ""]], [["门", "mén"], ["泊", "pō"], ["东", "dōng"], ["吴", "wú"], ["万", "wàn"], ["里", "lǐ"], ["船", "chuán"], ["。", ""]]], "sections": {"译文": "两只黄鹂在翠柳上鸣叫，一行白鹭飞上蓝天。从窗口看到西岭千年积雪，门前停泊着万里之外的船只。", "注释": "- **黄鹂**：黄莺。\n- **千秋雪**：千年不化的积雪。", "赏析": "此诗四句四景，两两对仗。黄鹂翠柳白鹭青天色彩明丽，千秋雪与万里船时空交织。", "作者": "杜甫（712年－770年），字子美，号少陵野老，唐代伟大的现实主义诗人，被后人誉为诗圣。"}}, {"title": "舟夜书所见", "poet": "查慎行", "dynasty": "清", "type": "五言绝句", "theme": "夜景", "tags": ["写景", "夜景", "渔火"], "grade": "03-二年级", "grade_label": "二年级", "lines": ["月黑见渔灯，", "孤光一点萤。", "微微风簇浪，", "散作满河星。"], "ruby": [[["月", "yuè"], ["黑", "hēi"], ["见", "jiàn"], ["渔", "yú"], ["灯", "dēng"], ["，", ""]], [["孤", "gū"], ["光", "guāng"], ["一", ""], ["点", "diǎn"], ["萤", "yíng"], ["。", ""]], [["微", "wēi"], ["微", "wēi"], ["风", "fēng"], ["簇", "cù"], ["浪", "làng"], ["，", ""]], [["散", "sàn"], ["作", "zuò"], ["满", "mǎn"], ["河", "hé"], ["星", "xīng"], ["。", ""]]], "sections": {"译文": "月黑的夜晚一盏渔灯闪烁，孤零零的灯光像萤火虫。微风吹起波浪，灯光散作满河的星星。", "注释": "- **渔灯**：渔船上的灯火。\n- **萤**：萤火虫。", "赏析": "此诗写夜泊所见之景。前两句写静态的渔灯，后两句化静为动，灯光散作满河星星，意境优美。", "作者": "查慎行（1650年－1727年），字悔余，号初白，清代诗人。"}}, {"title": "赋得古原草送别", "poet": "白居易", "dynasty": "唐", "type": "五言律诗", "theme": "送别", "tags": [], "grade": "03-二年级", "grade_label": "二年级", "lines": ["离离原上草，", "一岁一枯荣。", "野火烧不尽，", "春风吹又生。", "远芳侵古道，", "晴翠接荒城。", "又送王孙去，", "萋萋满别情。"], "ruby": [[["离", "lí"], ["离", "lí"], ["原", "yuán"], ["上", "shàng"], ["草", "cǎo"], ["，", ""]], [["一", ""], ["岁", "suì"], ["一", ""], ["枯", "kū"], ["荣", "róng"], ["。", ""]], [["野", "yě"], ["火", "huǒ"], ["烧", "shāo"], ["不", "bù"], ["尽", "jìn"], ["，", ""]], [["春", "chūn"], ["风", "fēng"], ["吹", "chuī"], ["又", "yòu"], ["生", "shēng"], ["。", ""]], [["远", "yuǎn"], ["芳", "fāng"], ["侵", "qīn"], ["古", "gǔ"], ["道", "dào"], ["，", ""]], [["晴", "qíng"], ["翠", "cuì"], ["接", "jiē"], ["荒", "huāng"], ["城", "chéng"], ["。", ""]], [["又", "yòu"], ["送", "sòng"], ["王", "wáng"], ["孙", "sūn"], ["去", "qù"], ["，", ""]], [["萋", "qī"], ["萋", "qī"], ["满", "mǎn"], ["别", "bié"], ["情", "qíng"], ["。", ""]]], "sections": {"译文": "原野上的草茂密繁盛，每年一度枯萎一度繁荣。野火烧也烧不尽它，春风一吹又蓬勃丛生。远处的芳草蔓延到古道，晴日下翠色连接荒城。又在这里送别友人远去，茂盛的芳草也满怀离情。", "注释": "- **离离**：繁盛的样子。\n- **枯荣**：枯萎与繁茂。\n- **王孙**：指被送别的人。\n- **萋萋**：草茂盛的样子。", "赏析": "“野火烧不尽，春风吹又生”写尽野草顽强的生命力，借咏草抒送别之情，气象阔大。", "作者": "白居易（772年－846年），字乐天，号香山居士，唐代诗人。"}}]}